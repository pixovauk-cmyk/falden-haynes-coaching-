---
import { reader } from '../lib/reader';

const ap   = await reader.singletons.about_page.read();
const site = await reader.singletons.site_settings.read();

const storyChip = ap?.story_chip ?? 'My journey';
const storyH2   = ap?.story_h2   ?? 'Where I came from.\nAnd why I coach.';
const storySub  = ap?.story_sub  ?? 'A story that starts earlier than most. And gets more honest along the way.';
const m1Tag     = ap?.m1_tag     ?? 'The start';
const m1H3      = ap?.m1_h3      ?? "I didn't wait for permission.";
const m1Body1   = ap?.m1_body1   ?? '';
const m1Body2   = ap?.m1_body2   ?? '';
const m2Tag     = ap?.m2_tag     ?? 'The real bit';
const m2H3      = ap?.m2_h3      ?? '35 businesses. Not all of them worked.';
const m2Body1   = ap?.m2_body1   ?? '';
const m2Body2   = ap?.m2_body2   ?? '';
const m3Tag     = ap?.m3_tag     ?? 'Why I coach';
const m3H3      = ap?.m3_h3      ?? 'I got tired of watching talented people get stuck.';
const m3Body1   = ap?.m3_body1   ?? '';
const m3Body2   = ap?.m3_body2   ?? "That's what I do. And that's why I do it.";
const m3Cta     = ap?.m3_cta     ?? 'Book a free call';
const calendly  = site?.calendly_discovery ?? 'https://calendly.com/feldon-haynes/discovery-call';
---

<section class="story" aria-label="Feldon's story and journey" id="story">
  <div class="container">

    <div class="story-header fade-in">
      <p class="eyebrow">
        <span class="eyebrow-line" aria-hidden="true"></span>
        {storyChip}
      </p>
      <h2 class="story-h2" set:html={storyH2.replace('\n', '<br>')}></h2>
      <p class="story-sub">{storySub}</p>
    </div>

    <!-- Timeline wrapper -->
    <div class="timeline">

      <!-- Milestone 1 -->
      <div class="milestone fade-in">
        <div class="milestone-text">
          <span class="milestone-tag">{m1Tag}</span>
          <h3 class="milestone-h3">{m1H3}</h3>
          <p class="milestone-body">{m1Body1}</p>
          <p class="milestone-body">{m1Body2}</p>
        </div>
        <div class="milestone-visual">
          <img
            src="/Images/feldon-haynes-seated-portrait.webp"
            alt="Feldon Haynes seated in a professional portrait"
            width="480"
            height="380"
            loading="lazy"
            class="milestone-img milestone-img--portrait"
          />
        </div>
      </div>

      <!-- Timeline connector -->
      <div class="timeline-connector" aria-hidden="true">
        <div class="connector-line"></div>
        <div class="connector-dot"></div>
      </div>

      <!-- Milestone 2 -->
      <div class="milestone milestone--reverse fade-in">
        <div class="milestone-text">
          <span class="milestone-tag">{m2Tag}</span>
          <h3 class="milestone-h3">{m2H3}</h3>
          <p class="milestone-body">{m2Body1}</p>
          <p class="milestone-body">{m2Body2}</p>
        </div>
        <div class="milestone-visual">
          <img
            src="/Images/feldon-haynes-whiteboard-strategy-session.webp"
            alt="Feldon Haynes mapping a client strategy on a whiteboard"
            width="480"
            height="380"
            loading="lazy"
            class="milestone-img"
          />
        </div>
      </div>

      <!-- Timeline connector -->
      <div class="timeline-connector" aria-hidden="true">
        <div class="connector-line"></div>
        <div class="connector-dot"></div>
      </div>

      <!-- Milestone 3 -->
      <div class="milestone fade-in">
        <div class="milestone-text">
          <span class="milestone-tag">{m3Tag}</span>
          <h3 class="milestone-h3">{m3H3}</h3>
          <p class="milestone-body">{m3Body1}</p>
          <p class="milestone-body">{m3Body2}</p>
          <a href={calendly} class="milestone-cta" target="_blank" rel="noopener noreferrer">
            {m3Cta}
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M2.5 7h9M8 3.5L11.5 7 8 10.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
        <div class="milestone-visual">
          <img
            src="/Images/feldon-haynes-sales-funnel-training.webp"
            alt="Feldon Haynes presenting coaching frameworks on a whiteboard"
            width="480"
            height="380"
            loading="lazy"
            class="milestone-img"
          />
        </div>
      </div>

    </div>

  </div>
</section>

<style>
  .story {
    background: #FAF9F6;
    padding: 80px 0;
  }

  /* Header */
  .story-header {
    text-align: center;
    margin-bottom: 64px;
  }
  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #534AB7;
    margin-bottom: 14px;
  }
  .eyebrow-line {
    display: inline-block;
    width: 28px;
    height: 1px;
    background: #F2D832;
    flex-shrink: 0;
  }
  .story-h2 {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 44px;
    font-weight: 800;
    letter-spacing: -0.03em;
    color: #1a1744;
    line-height: 1.1;
    margin-bottom: 14px;
  }
  .story-sub {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 16px;
    font-weight: 400;
    color: #7e7a9f;
    max-width: 420px;
    margin: 0 auto;
    line-height: 1.7;
  }

  /* Timeline */
  .timeline {
    display: flex;
    flex-direction: column;
    gap: 0;
    max-width: 1060px;
    margin: 0 auto;
  }

  /* Each milestone: two-column image + text */
  .milestone {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
    padding: 48px 0;
  }
  .milestone--reverse {
    direction: rtl;
  }
  .milestone--reverse > * {
    direction: ltr;
  }

  /* Milestone text */
  .milestone-tag {
    display: inline-block;
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #534AB7;
    background: #EEEDFE;
    padding: 4px 12px;
    border-radius: 9999px;
    margin-bottom: 16px;
  }

  .milestone-h3 {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 28px;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: #1a1744;
    line-height: 1.2;
    margin-bottom: 18px;
  }

  .milestone-body {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 15px;
    font-weight: 400;
    color: #5a5680;
    line-height: 1.8;
    margin-bottom: 14px;
  }
  .milestone-body:last-of-type { margin-bottom: 0; }

  .milestone-cta {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: #534AB7;
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 14px;
    font-weight: 700;
    text-decoration: none;
    border-bottom: 2px solid #F2D832;
    padding-bottom: 2px;
    margin-top: 20px;
    transition: color 0.2s;
  }
  .milestone-cta:hover { color: #3b309e; }

  /* Image */
  .milestone-img {
    width: 100%;
    height: 340px;
    object-fit: cover;
    object-position: center 30%;
    border-radius: 20px;
    display: block;
    background: linear-gradient(135deg, #EEEDFE 0%, #e3dfff 100%);
  }
  .milestone-img--portrait {
    object-position: center 15%;
  }

  /* Timeline connectors */
  .timeline-connector {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    padding: 0;
  }
  .connector-line {
    width: 2px;
    height: 32px;
    background: linear-gradient(to bottom, #EEEDFE, #534AB7);
  }
  .connector-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: #534AB7;
    border: 3px solid #FAF9F6;
    box-shadow: 0 0 0 3px #534AB7;
  }

  /* ── Tablet ──────────────────────────────── */
  @media (max-width: 1024px) {
    .milestone {
      grid-template-columns: 1fr;
      gap: 28px;
      direction: ltr;
      padding: 32px 0;
    }
    .milestone--reverse { direction: ltr; }
    .milestone-img { height: 260px; }
    .story-h2 { font-size: 34px; }
    .milestone-h3 { font-size: 24px; }
    .timeline-connector { display: none; }
  }

  /* ── Mobile ──────────────────────────────── */
  @media (max-width: 640px) {
    .story { padding: 52px 0; }
    .story-h2 { font-size: 26px; }
    .story-header { margin-bottom: 40px; }
    .milestone { padding: 24px 0; gap: 20px; }
    .milestone-img { height: 220px; }
    .milestone-h3 { font-size: 20px; }
  }
</style>
