---
// ServicesSection.astro — Two groups of 3 services each
// Business Start-up Services + Business to Business Services
// Sits before BundleCards on the homepage
---

<section class="services" id="what-i-do" aria-label="Services">
  <div class="container">

    <!-- Section header -->
    <div class="services-header fade-in">
      <span class="svc-chip">What I do</span>
      <h2 class="svc-h2">Start it. Build it. Run it properly.</h2>
      <p class="svc-intro">
        Six ways I work with founders and business owners,
        from the first idea to the systems that keep everything moving.
      </p>
    </div>

    <!-- Group 1: Business Start-up Services -->
    <div class="svc-group fade-in">
      <div class="svc-group-header">
        <span class="svc-group-chip">Business start-up</span>
        <p class="svc-group-desc">For founders who are starting from scratch, or almost there.</p>
      </div>
      <div class="svc-scroll-wrap" id="svc-scroll-1">
      <div class="svc-cards">

        <article class="svc-card svc-card--graphic">
          <div class="svc-card-graphic-wrap">
            <img
              src="/Images/Business plan2.webp"
              alt="Small business planning session with Feldon Haynes coaching"
              class="svc-card-graphic"
              loading="lazy"
              width="800"
              height="800"
            />
          </div>
          <h3 class="svc-card-title">Business Planning</h3>
          <p class="svc-card-body">
            Starting without a plan isn't bold. It's expensive. A proper business
            plan tells you exactly what to do next. Not at some point. Right now.
            Clear action steps, honest financials, and a roadmap you can actually follow.
          </p>
          <a href="/contact" class="svc-link" aria-label="Learn more about Business Planning">
            Learn more
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </article>

        <article class="svc-card svc-card--graphic">
          <div class="svc-card-graphic-wrap">
            <img
              src="/Images/Business%20registration2.webp"
              alt="Business registration guidance for UK small business owners"
              class="svc-card-graphic"
              loading="lazy"
              width="800"
              height="800"
            />
          </div>
          <h3 class="svc-card-title">Business Registration</h3>
          <p class="svc-card-body">
            The admin side of starting can stop you before you've begun.
            I'll guide you through company setup, structure, HMRC registration,
            intellectual property, and grant applications, with expert partners
            ready to step in where needed.
          </p>
          <a href="/contact" class="svc-link" aria-label="Learn more about Business Registration">
            Learn more
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </article>

        <article class="svc-card svc-card--graphic">
          <div class="svc-card-graphic-wrap">
            <img
              src="/Images/1-2-12.webp"
              alt="One-to-one business coaching session with Feldon Haynes"
              class="svc-card-graphic"
              loading="lazy"
              width="800"
              height="800"
            />
          </div>
          <h3 class="svc-card-title">One-to-One Coaching</h3>
          <p class="svc-card-body">
            You don't need a coach who's read about business. You need one who's
            built it. I work with founders on their real challenges, not the
            textbook ones, giving you the tools and confidence to make better
            decisions and move faster.
          </p>
          <a href="/contact" class="svc-link" aria-label="Learn more about One-to-One Coaching">
            Learn more
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </article>

      </div>
      </div>
      <div class="svc-carousel-nav" aria-label="Scroll cards">
        <button class="svc-carousel-btn" id="svc-prev-1" aria-label="Previous">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true"><path d="M11 4L6 9l5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <button class="svc-carousel-btn" id="svc-next-1" aria-label="Next">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true"><path d="M7 4l5 5-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
      </div>
    </div>

    <!-- Group 2: Business to Business Services -->
    <div class="svc-group fade-in">
      <div class="svc-group-header">
        <span class="svc-group-chip svc-group-chip--b2b">Business to business</span>
        <p class="svc-group-desc">For businesses that are up and running, and need to run better.</p>
      </div>
      <div class="svc-scroll-wrap" id="svc-scroll-2">
      <div class="svc-cards">

        <article class="svc-card svc-card--graphic">
          <div class="svc-card-graphic-wrap">
            <img
              src="/Images/Adminstration3.webp"
              alt="Administration support services for small business owners"
              class="svc-card-graphic"
              loading="lazy"
              width="800"
              height="800"
            />
          </div>
          <h3 class="svc-card-title">Administration Support</h3>
          <p class="svc-card-body">
            The details that slow you down. The tasks that eat your day.
            Reliable, ad hoc admin support that keeps your business organised
            and running smoothly, so you can focus on the things that actually
            need your attention.
          </p>
          <a href="/contact" class="svc-link" aria-label="Learn more about Administration Support">
            Learn more
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </article>

        <article class="svc-card svc-card--graphic">
          <div class="svc-card-graphic-wrap">
            <img
              src="/Images/Sop3.webp"
              alt="Standard operating procedures for small business structure and scale"
              class="svc-card-graphic"
              loading="lazy"
              width="800"
              height="800"
            />
          </div>
          <h3 class="svc-card-title">Standard Operating Processes</h3>
          <p class="svc-card-body">
            When your business runs differently every time, it can't scale.
            I build SOPs that reflect how your business actually works,
            making everyday tasks consistent, repeatable, and easy to hand
            over without things falling apart.
          </p>
          <a href="/contact" class="svc-link" aria-label="Learn more about Standard Operating Processes">
            Learn more
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </article>

        <article class="svc-card svc-card--graphic">
          <div class="svc-card-graphic-wrap">
            <img
              src="/Images/projectmanagment3.webp"
              alt="Project management support for founders launching or improving their business"
              class="svc-card-graphic"
              loading="lazy"
              width="800"
              height="800"
            />
          </div>
          <h3 class="svc-card-title">Project Management</h3>
          <p class="svc-card-body">
            New launch. Process improvement. Whatever it is, I bring the
            structure and momentum to get it done properly. Not just started.
            Finished. On time, with clear goals and someone accountable
            for every moving part.
          </p>
          <a href="/contact" class="svc-link" aria-label="Learn more about Project Management">
            Learn more
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </article>

      </div>
      </div>
      <div class="svc-carousel-nav" aria-label="Scroll cards">
        <button class="svc-carousel-btn" id="svc-prev-2" aria-label="Previous">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true"><path d="M11 4L6 9l5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <button class="svc-carousel-btn" id="svc-next-2" aria-label="Next">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true"><path d="M7 4l5 5-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
      </div>
    </div>

  </div>
</section>

<style>
  .services {
    background: #ffffff;
    padding: 80px 0;
  }

  /* ── Header ─────────────────────────────── */
  .services-header {
    text-align: center;
    margin-bottom: 48px;
  }

  .svc-chip {
    display: inline-flex;
    align-items: center;
    background: #e3dfff;
    color: #3b309e;
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 7px 18px;
    border-radius: 9999px;
    margin-bottom: 24px;
  }

  .svc-h2 {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 52px;
    font-weight: 800;
    letter-spacing: -0.03em;
    color: #1a1744;
    line-height: 1.1;
    margin-bottom: 18px;
  }

  .svc-intro {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 18px;
    font-weight: 400;
    color: #7e7a9f;
    max-width: 480px;
    margin: 0 auto;
    line-height: 1.7;
  }

  /* ── Groups ─────────────────────────────── */
  .svc-group {
    margin-bottom: 44px;
  }
  .svc-group:last-child {
    margin-bottom: 0;
  }

  .svc-group-header {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-bottom: 32px;
    padding-bottom: 24px;
    border-bottom: 1px solid #ede9ff;
  }

  .svc-group-chip {
    display: inline-flex;
    align-items: center;
    background: #534ab7;
    color: #ffffff;
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 8px 20px;
    border-radius: 9999px;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .svc-group-chip--b2b {
    background: #1a1744;
  }

  .svc-group-desc {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 16px;
    font-weight: 400;
    color: #7e7a9f;
    line-height: 1.5;
  }

  /* ── 3-col card grid ────────────────────── */
  .svc-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  /* Card */
  .svc-card {
    background: #f8f9fb;
    border-radius: 20px;
    border: 1px solid #ede9ff;
    padding: 36px 32px;
    display: flex;
    flex-direction: column;
    gap: 0;
    overflow: hidden;
    transition: transform 0.22s ease, box-shadow 0.22s ease, background 0.2s ease;
  }
  .svc-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 16px 48px rgba(59, 48, 158, 0.11);
    background: #ffffff;
  }

  /* Graphic wrapper — bleeds to card edges, holds the background */
  .svc-card-graphic-wrap {
    width: calc(100% + 64px);
    margin: -36px -32px 28px;
    height: 220px;
    background: #ede9ff;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  /* Illustration sits inside the wrapper */
  .svc-card-graphic {
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center;
    display: block;
  }

  /* Icon */
  .svc-icon {
    width: 52px;
    height: 52px;
    background: #e3dfff;
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #534ab7;
    margin-bottom: 24px;
    flex-shrink: 0;
    transition: background 0.2s ease;
  }
  .svc-card:hover .svc-icon {
    background: #534ab7;
    color: #ffffff;
  }

  /* Title */
  .svc-card-title {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 20px;
    font-weight: 700;
    color: #1a1744;
    line-height: 1.25;
    margin-bottom: 14px;
  }

  /* Body */
  .svc-card-body {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 15px;
    font-weight: 400;
    color: #7e7a9f;
    line-height: 1.75;
    flex: 1;
    margin-bottom: 28px;
  }

  /* Learn more link */
  .svc-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 15px;
    font-weight: 600;
    color: #534ab7;
    transition: gap 0.2s ease, color 0.2s ease;
    align-self: flex-start;
  }
  .svc-link:hover {
    color: #3b309e;
    gap: 12px;
  }

  /* ── Tablet ──────────────────────────────── */
  @media (max-width: 1024px) {
    .svc-cards {
      grid-template-columns: repeat(2, 1fr);
    }
    .svc-card:last-child {
      grid-column: 1 / -1;
      max-width: 520px;
    }
  }

  /* Carousel nav — hidden on desktop */
  .svc-carousel-nav {
    display: none;
    justify-content: center;
    gap: 12px;
    margin-top: 16px;
  }
  .svc-carousel-btn {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: #534AB7;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #ffffff;
    transition: background 0.2s, transform 0.1s;
    flex-shrink: 0;
  }
  .svc-carousel-btn:hover { background: #3b309e; }
  .svc-carousel-btn:active { transform: scale(0.95); }

  /* ── Mobile ─────────────────────────────── */
  @media (max-width: 768px) {
    .services { padding: 52px 0; }
    .svc-h2 { font-size: 34px; }
    .svc-group-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 12px;
    }

    .svc-scroll-wrap {
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      scrollbar-width: none;
      -ms-overflow-style: none;
      margin: 0 -16px;
      padding: 0 16px 4px;
    }
    .svc-scroll-wrap::-webkit-scrollbar { display: none; }

    .svc-cards {
      display: flex;
      flex-wrap: nowrap;
      width: max-content;
      gap: 14px;
    }

    .svc-card {
      width: calc(85vw);
      flex-shrink: 0;
      scroll-snap-align: start;
    }
    .svc-card:last-child {
      grid-column: auto;
      max-width: 100%;
    }

    .svc-carousel-nav { display: flex; }
  }
</style>

<script>
  [['svc-scroll-1','svc-prev-1','svc-next-1'],['svc-scroll-2','svc-prev-2','svc-next-2']].forEach(([sid, pid, nid]) => {
    const wrap = document.getElementById(sid);
    const prev = document.getElementById(pid);
    const next = document.getElementById(nid);
    if (!wrap || !prev || !next) return;
    const step = () => { const c = wrap.querySelector('.svc-card'); return c ? c.offsetWidth + 14 : 300; };
    prev.addEventListener('click', () => wrap.scrollBy({ left: -step(), behavior: 'smooth' }));
    next.addEventListener('click', () => wrap.scrollBy({ left: step(), behavior: 'smooth' }));
  });
</script>
