---
// Testimonials.astro — real Trustpilot reviews
// TODO: replace placeholder display names with real reviewer first names once Feldon confirms from Trustpilot
---

<section class="testimonials" aria-label="Client testimonials">

  <div class="t-bg-circle t-bg-circle--1" aria-hidden="true"></div>
  <div class="t-bg-circle t-bg-circle--2" aria-hidden="true"></div>
  <div class="t-bg-circle t-bg-circle--3" aria-hidden="true"></div>

  <div class="container">

    <!-- Trustpilot badge -->
    <div class="tp-badge-wrap fade-in">
      <a
        href="https://uk.trustpilot.com/review/feldeluxe.com"
        target="_blank"
        rel="noopener noreferrer"
        class="tp-badge"
      >
        <svg class="tp-star-icon" width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <rect width="24" height="24" rx="5" fill="#00B67A"/>
          <path d="M12 4.24L13.79 9.67H19.5L14.95 12.8L16.74 18.24L12 15.1L7.26 18.24L9.05 12.8L4.5 9.67H10.21L12 4.24Z" fill="white"/>
        </svg>
        <span class="tp-wordmark">Trustpilot</span>
        <span class="tp-sep" aria-hidden="true">·</span>
        <span class="tp-stars-row" aria-label="5 stars">★★★★★</span>
        <span class="tp-count">4 verified reviews</span>
      </a>
    </div>

    <!-- Header -->
    <div class="testimonials-header fade-in">
      <h2 class="t-h2">Honest words from people<br>I've worked with.</h2>
      <p class="t-subhead">Real feedback from founders and business owners. Verified on Trustpilot.</p>
    </div>

    <!-- Cards -->
    <div class="t-scroll-wrap" id="tp-scroll">
    <div class="t-grid">

      <!-- Card 1 — Marketing webinar attendee -->
      <article class="t-card fade-in">
        <div class="t-card-top">
          <span class="t-stars" aria-label="5 out of 5 stars">★★★★★</span>
          <span class="t-verified">
            <svg width="9" height="9" viewBox="0 0 9 9" fill="none" aria-hidden="true">
              <circle cx="4.5" cy="4.5" r="4.5" fill="#00B67A"/>
              <path d="M2.5 4.5L3.9 5.9L6.5 3.5" stroke="white" stroke-width="1.1" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Verified
          </span>
        </div>
        <p class="t-quote">
          "I attended a marketing webinar led by Feldon Haynes. I felt very welcome as Feldon was very friendly and supportive throughout. He was ensuring that everyone understood everything well. He explained everything very clearly and even answered my questions in depth. I am glad I got the chance to attend. I learnt a lot. Thank you very much Feldon!"
        </p>
        <div class="t-author">
          <div class="t-avatar t-avatar--purple" aria-hidden="true">W</div>
          <div class="t-author-info">
            <!-- TODO: replace with real first name once Feldon confirms -->
            <span class="t-name">Workshop Attendee</span>
            <span class="t-source">
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <rect width="24" height="24" rx="5" fill="#00B67A"/>
                <path d="M12 4.24L13.79 9.67H19.5L14.95 12.8L16.74 18.24L12 15.1L7.26 18.24L9.05 12.8L4.5 9.67H10.21L12 4.24Z" fill="white"/>
              </svg>
              Trustpilot review
            </span>
          </div>
        </div>
      </article>

      <!-- Card 2 — Grant research client -->
      <article class="t-card fade-in">
        <div class="t-card-top">
          <span class="t-stars" aria-label="5 out of 5 stars">★★★★★</span>
          <span class="t-verified">
            <svg width="9" height="9" viewBox="0 0 9 9" fill="none" aria-hidden="true">
              <circle cx="4.5" cy="4.5" r="4.5" fill="#00B67A"/>
              <path d="M2.5 4.5L3.9 5.9L6.5 3.5" stroke="white" stroke-width="1.1" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Verified
          </span>
        </div>
        <p class="t-quote">
          "I reached out to Feldon because he was recommended to me as someone who could help with Grant Research. I was looking at a new venture and was a bit lost in the world of grants. We had a call and Feldon was extremely helpful and friendly. He assisted me with places to look, people to contact, and even specific grants to consider applying for."
        </p>
        <div class="t-author">
          <div class="t-avatar t-avatar--navy" aria-hidden="true">N</div>
          <div class="t-author-info">
            <!-- TODO: replace with real first name once Feldon confirms -->
            <span class="t-name">New Venture Founder</span>
            <span class="t-source">
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <rect width="24" height="24" rx="5" fill="#00B67A"/>
                <path d="M12 4.24L13.79 9.67H19.5L14.95 12.8L16.74 18.24L12 15.1L7.26 18.24L9.05 12.8L4.5 9.67H10.21L12 4.24Z" fill="white"/>
              </svg>
              Trustpilot review
            </span>
          </div>
        </div>
      </article>

      <!-- Card 3 — Employment contracts client -->
      <article class="t-card fade-in">
        <div class="t-card-top">
          <span class="t-stars" aria-label="5 out of 5 stars">★★★★★</span>
          <span class="t-verified">
            <svg width="9" height="9" viewBox="0 0 9 9" fill="none" aria-hidden="true">
              <circle cx="4.5" cy="4.5" r="4.5" fill="#00B67A"/>
              <path d="M2.5 4.5L3.9 5.9L6.5 3.5" stroke="white" stroke-width="1.1" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Verified
          </span>
        </div>
        <p class="t-quote">
          "Feldon arranged the meetings to go through our employment contracts, privacy policies and induction and termination procedures. He was able to draw up a new employment contract to meet with current legislation."
        </p>
        <div class="t-author">
          <div class="t-avatar t-avatar--gold" aria-hidden="true">B</div>
          <div class="t-author-info">
            <!-- TODO: replace with real first name once Feldon confirms -->
            <span class="t-name">Business Owner</span>
            <span class="t-source">
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <rect width="24" height="24" rx="5" fill="#00B67A"/>
                <path d="M12 4.24L13.79 9.67H19.5L14.95 12.8L16.74 18.24L12 15.1L7.26 18.24L9.05 12.8L4.5 9.67H10.21L12 4.24Z" fill="white"/>
              </svg>
              Trustpilot review
            </span>
          </div>
        </div>
      </article>

    </div>
    </div>

    <!-- Mobile carousel nav -->
    <div class="t-carousel-nav" aria-label="Scroll testimonials">
      <button class="t-carousel-btn" id="tp-prev" aria-label="Previous">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true"><path d="M11 4L6 9l5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
      <button class="t-carousel-btn" id="tp-next" aria-label="Next">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true"><path d="M7 4l5 5-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
    </div>

    <!-- Footer link -->
    <div class="t-footer fade-in">
      <a
        href="https://uk.trustpilot.com/review/feldeluxe.com"
        target="_blank"
        rel="noopener noreferrer"
        class="t-all-reviews"
      >
        Read all reviews on Trustpilot
        <svg width="13" height="13" viewBox="0 0 13 13" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M2.5 6.5h8M7.5 3.5L10.5 6.5l-3 3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>

  </div>
</section>

<style>
  .testimonials {
    background: linear-gradient(135deg, #1a1744 0%, #26215C 50%, #2d2a6e 100%);
    padding: 64px 0 56px;
    position: relative;
    overflow: hidden;
  }

  .t-bg-circle {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    z-index: 0;
  }
  .t-bg-circle--1 {
    width: 560px; height: 560px;
    background: rgba(255,255,255,0.03);
    top: -180px; right: -140px;
  }
  .t-bg-circle--2 {
    width: 340px; height: 340px;
    background: rgba(255,255,255,0.04);
    bottom: -120px; left: -90px;
  }
  .t-bg-circle--3 {
    width: 200px; height: 200px;
    background: rgba(0,182,122,0.05);
    top: 40%; left: 55%;
    transform: translate(-50%,-50%);
  }

  .container { position: relative; z-index: 1; }

  /* ── Trustpilot badge ────────────────────── */
  .tp-badge-wrap {
    display: flex;
    justify-content: center;
    margin-bottom: 28px;
  }

  .tp-badge {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 9999px;
    padding: 9px 20px;
    text-decoration: none;
    transition: background 0.2s;
  }
  .tp-badge:hover { background: rgba(255,255,255,0.16); }

  .tp-star-icon { flex-shrink: 0; display: block; }

  .tp-wordmark {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 14px;
    font-weight: 700;
    color: #ffffff;
    letter-spacing: -0.01em;
  }

  .tp-sep {
    color: rgba(255,255,255,0.35);
    font-size: 14px;
  }

  .tp-stars-row {
    font-size: 15px;
    color: #00B67A;
    letter-spacing: 2px;
    line-height: 1;
  }

  .tp-count {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 12px;
    font-weight: 400;
    color: rgba(255,255,255,0.6);
    white-space: nowrap;
  }

  /* ── Header ──────────────────────────────── */
  .testimonials-header {
    text-align: center;
    margin-bottom: 36px;
  }

  .t-h2 {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 38px;
    font-weight: 800;
    color: #ffffff;
    line-height: 1.12;
    letter-spacing: -0.03em;
    margin-bottom: 12px;
  }

  .t-subhead {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 15px;
    font-weight: 400;
    color: rgba(255,255,255,0.6);
    max-width: 380px;
    margin: 0 auto;
    line-height: 1.65;
  }

  /* ── Scroll wrapper ──────────────────────── */
  .t-scroll-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding-bottom: 8px;
  }
  .t-scroll-wrap::-webkit-scrollbar { display: none; }

  /* ── Grid — centred on desktop ───────────── */
  .t-grid {
    display: flex;
    flex-direction: row;
    flex-wrap: nowrap;
    gap: 16px;
    justify-content: center; /* cards sit in the middle on wide screens */
  }

  /* ── Glass card ──────────────────────────── */
  .t-card {
    background: rgba(255,255,255,0.09);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(255,255,255,0.14);
    border-radius: 18px;
    padding: 22px 20px 20px;
    display: flex;
    flex-direction: column;
    width: 260px;
    flex-shrink: 0;
    scroll-snap-align: start;
    transition: background 0.22s, transform 0.22s, border-color 0.22s;
  }
  .t-card:hover {
    background: rgba(255,255,255,0.14);
    border-color: rgba(255,255,255,0.24);
    transform: translateY(-4px);
  }

  /* ── Card top — stars + verified ─────────── */
  .t-card-top {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 14px;
    gap: 8px;
  }

  .t-stars {
    font-size: 17px;
    color: #00B67A !important;
    -webkit-text-fill-color: #00B67A;
    letter-spacing: 2px;
    line-height: 1;
    flex-shrink: 0;
  }

  .t-verified {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    background: rgba(0,182,122,0.15);
    border: 1px solid rgba(0,182,122,0.35);
    color: #00B67A;
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.04em;
    padding: 3px 9px 3px 6px;
    border-radius: 9999px;
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* ── Quote ───────────────────────────────── */
  .t-quote {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 14px;
    font-weight: 400;
    color: rgba(255,255,255,0.85);
    line-height: 1.75;
    margin-bottom: 20px;
    font-style: italic;
    display: -webkit-box;
    -webkit-line-clamp: 5;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ── Author row ──────────────────────────── */
  .t-author {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 12px;
    padding-top: 18px;
    border-top: 1px solid rgba(255,255,255,0.1);
  }

  /* ── Initial avatars ─────────────────────── */
  .t-avatar {
    width: 42px;
    height: 42px;
    border-radius: 50%;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 16px;
    font-weight: 800;
    border: 2px solid rgba(255,255,255,0.2);
  }

  .t-avatar--purple {
    background-color: #534AB7;
    color: #ffffff;
  }

  .t-avatar--navy {
    background-color: #3d3882;
    color: rgba(255,255,255,0.9);
  }

  .t-avatar--gold {
    background-color: #F2D832;
    color: #26215C;
  }

  .t-author-info {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .t-name {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 14px;
    font-weight: 700;
    color: #ffffff;
  }

  .t-source {
    display: flex;
    align-items: center;
    gap: 5px;
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 12px;
    font-weight: 400;
    color: rgba(255,255,255,0.5);
  }

  /* ── Footer link ─────────────────────────── */
  .t-footer {
    display: flex;
    justify-content: center;
    margin-top: 36px;
  }

  .t-all-reviews {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border: 1px solid rgba(255,255,255,0.3);
    color: rgba(255,255,255,0.8);
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 14px;
    font-weight: 600;
    padding: 13px 26px;
    border-radius: 9999px;
    text-decoration: none;
    transition: background 0.2s, border-color 0.2s, color 0.2s;
  }
  .t-all-reviews:hover {
    background: rgba(255,255,255,0.1);
    border-color: rgba(255,255,255,0.5);
    color: #ffffff;
  }

  /* ── Tablet — cards overflow, scroll left ── */
  @media (max-width: 900px) {
    .t-h2 { font-size: 30px; }
    .t-scroll-wrap {
      margin: 0 -16px;
      padding: 0 16px 12px;
    }
    .t-grid {
      justify-content: flex-start; /* start from left so scroll works */
      width: max-content;
    }
    .t-card { width: 250px; }
  }

  /* Carousel nav — hidden on desktop */
  .t-carousel-nav {
    display: none;
    justify-content: center;
    gap: 12px;
    margin-top: 20px;
  }
  .t-carousel-btn {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: rgba(255,255,255,0.15);
    border: 1px solid rgba(255,255,255,0.3);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #ffffff;
    transition: background 0.2s, transform 0.1s;
    flex-shrink: 0;
  }
  .t-carousel-btn:hover { background: rgba(255,255,255,0.25); }
  .t-carousel-btn:active { transform: scale(0.95); }

  /* ── Mobile ──────────────────────────────── */
  @media (max-width: 640px) {
    .testimonials { padding: 48px 0 44px; }
    .t-h2 { font-size: 24px; }
    .testimonials-header { margin-bottom: 28px; }
    .tp-sep { display: none; }
    .tp-count { display: none; }
    .tp-badge { gap: 8px; padding: 8px 14px; }

    .t-scroll-wrap {
      margin: 0 -16px;
      padding: 0 16px 4px;
    }

    .t-grid {
      justify-content: flex-start;
      width: max-content;
    }

    .t-card {
      width: calc(88vw);
      scroll-snap-align: start;
    }

    .t-quote { -webkit-line-clamp: unset; }

    .t-carousel-nav { display: flex; }
  }
</style>

<script>
  const tpWrap = document.getElementById('tp-scroll');
  const tpPrev = document.getElementById('tp-prev');
  const tpNext = document.getElementById('tp-next');
  if (tpWrap && tpPrev && tpNext) {
    const step = () => { const c = tpWrap.querySelector('.t-card'); return c ? c.offsetWidth + 16 : 280; };
    tpPrev.addEventListener('click', () => tpWrap.scrollBy({ left: -step(), behavior: 'smooth' }));
    tpNext.addEventListener('click', () => tpWrap.scrollBy({ left: step(), behavior: 'smooth' }));
  }
</script>
