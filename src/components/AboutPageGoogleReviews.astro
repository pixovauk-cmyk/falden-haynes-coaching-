      </div>
    </div>

    <div class="gr-footer fade-in">
      <a
        href="https://www.google.com/search?q=feldeluxe"
        target="_blank"
        rel="noopener noreferrer"
        class="gr-link"
      >
        Read all reviews on Google
        <svg width="13" height="13" viewBox="0 0 13 13" fill="none" aria-hidden="true">
          <path d="M2.5 6.5h8M7.5 3.5L10.5 6.5l-3 3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>

  </div>
</section>

<style>
  .google-reviews {
    background: #ffffff;
    padding: 80px 0;
  }

  /* Header */
  .gr-header { text-align: center; margin-bottom: 44px; }

  .gr-badge-wrap { display: flex; justify-content: center; margin-bottom: 22px; }
  .gr-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #f8f9fb;
    border: 1px solid #e8e8f0;
    border-radius: 9999px;
    padding: 8px 18px;
  }
  .gr-badge-text {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 13px;
    font-weight: 700;
    color: #1a1744;
  }
  .gr-sep { color: #ddd; }
  .gr-stars-badge {
    color: #FBBC05 !important;
    -webkit-text-fill-color: #FBBC05;
    font-size: 13px;
    letter-spacing: 1px;
  }
  .gr-count {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 12px;
    color: #9c97c0;
  }

  .gr-h2 {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 38px;
    font-weight: 800;
    letter-spacing: -0.03em;
    color: #1a1744;
    line-height: 1.1;
    margin-bottom: 12px;
  }
  .gr-sub {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 16px;
    font-weight: 400;
    color: #7e7a9f;
    max-width: 360px;
    margin: 0 auto;
    line-height: 1.7;
  }

  /* Desktop grid: first 3 in a row, last 2 centred below */
  .gr-scroll-wrap { padding-bottom: 4px; }

  .gr-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-bottom: 32px;
  }

  /* 4th and 5th card span full row then auto-place centred */
  .gr-card:nth-child(4) { grid-column: 1; }
  .gr-card:nth-child(4),
  .gr-card:nth-child(5) { }

  /* For the bottom row of 2: start them in the middle col */
  @media (min-width: 769px) {
    .gr-grid {
      grid-template-rows: auto auto;
    }
    .gr-card:nth-child(4) { grid-column: 1; grid-row: 2; }
    .gr-card:nth-child(5) { grid-column: 2; grid-row: 2; }
  }

  /* Card */
  .gr-card {
    background: #f8f9fb;
    border: 1px solid #e8e8f0;
    border-radius: 20px;
    padding: 22px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    transition: box-shadow 0.2s, border-color 0.2s;
  }
  .gr-card:hover { box-shadow: 0 6px 28px rgba(26,23,68,0.08); border-color: #d0cce8; }

  /* Top row */
  .gr-top { display: flex; align-items: center; gap: 10px; }
  .gr-glogo { margin-left: auto; flex-shrink: 0; }

  .gr-avatar {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 15px;
    font-weight: 800;
    color: #ffffff;
  }

  .gr-info { display: flex; flex-direction: column; gap: 2px; }
  .gr-name {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 14px;
    font-weight: 700;
    color: #1a1744;
  }
  .gr-meta {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 11px;
    color: #9c97c0;
  }

  .gr-stars {
    font-size: 15px;
    color: #FBBC05 !important;
    -webkit-text-fill-color: #FBBC05;
    letter-spacing: 2px;
    line-height: 1;
  }

  .gr-quote {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 14px;
    font-weight: 400;
    color: #5a5680;
    line-height: 1.75;
    font-style: italic;
    flex: 1;
  }

  /* Footer */
  .gr-footer { display: flex; justify-content: center; }
  .gr-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border: 1px solid #d0cce8;
    color: #534AB7;
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 14px;
    font-weight: 600;
    padding: 12px 24px;
    border-radius: 9999px;
    text-decoration: none;
    transition: background 0.2s, border-color 0.2s;
  }
  .gr-link:hover { background: #f0eff8; border-color: #b8b2f0; }

  /* ── Tablet ──────────────────────────────── */
  @media (max-width: 1024px) {
    .gr-h2 { font-size: 30px; }
    .gr-grid { grid-template-columns: repeat(2, 1fr); }
    .gr-card:nth-child(4),
    .gr-card:nth-child(5) { grid-column: auto; grid-row: auto; }
  }

  /* ── Mobile swipe ────────────────────────── */
  @media (max-width: 768px) {
    .google-reviews { padding: 52px 0; }
    .gr-h2 { font-size: 24px; }

    .gr-scroll-wrap {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      scroll-snap-type: x mandatory;
      scrollbar-width: none;
      -ms-overflow-style: none;
      margin: 0 -16px;
      padding: 0 16px 12px;
    }
    .gr-scroll-wrap::-webkit-scrollbar { display: none; }

    .gr-grid {
      display: flex;
      flex-wrap: nowrap;
      width: max-content;
      gap: 14px;
      margin-bottom: 24px;
    }
    .gr-card {
      width: 260px;
      flex-shrink: 0;
      scroll-snap-align: start;
    }
    .gr-card:nth-child(4),
    .gr-card:nth-child(5) { grid-column: auto; grid-row: auto; }
  }
</style>
