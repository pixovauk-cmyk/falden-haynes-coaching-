<style>
  .google-reviews {
    background: #ffffff;
    padding: 80px 0;
  }

  /* Header */
  .gr-header { text-align: center; margin-bottom: 44px; }

  .gr-badge-wrap { display: flex; justify-content: center; margin-bottom: 22px; }
  .gr-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #f8f9fb;
    border: 1px solid #e8e8f0;
    border-radius: 9999px;
    padding: 8px 18px;
  }
  .gr-badge-text {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 13px;
    font-weight: 700;
    color: #1a1744;
  }
  .gr-sep { color: #ddd; }
  .gr-stars-badge {
    color: #FBBC05 !important;
    -webkit-text-fill-color: #FBBC05;
    font-size: 13px;
    letter-spacing: 1px;
  }
  .gr-count {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 12px;
    color: #9c97c0;
  }

  .gr-h2 {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 38px;
    font-weight: 800;
    letter-spacing: -0.03em;
    color: #1a1744;
    line-height: 1.1;
    margin-bottom: 12px;
  }
  .gr-sub {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 16px;
    font-weight: 400;
    color: #7e7a9f;
    max-width: 360px;
    margin: 0 auto;
    line-height: 1.7;
  }

  /* Desktop marquee */
  @keyframes gr-marquee {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  .gr-scroll-wrap {
    overflow: hidden;
    position: relative;
    padding-bottom: 4px;
  }
  /* Fade edges */
  .gr-scroll-wrap::before,
  .gr-scroll-wrap::after {
    content: '';
    position: absolute;
    top: 0; bottom: 0;
    width: 80px;
    z-index: 2;
    pointer-events: none;
  }
  .gr-scroll-wrap::before { left: 0; background: linear-gradient(to right, #ffffff, transparent); }
  .gr-scroll-wrap::after  { right: 0; background: linear-gradient(to left, #ffffff, transparent); }

  .gr-track {
    display: flex;
    width: max-content;
    animation: gr-marquee 32s linear infinite;
  }
  .gr-track:hover { animation-play-state: paused; }

  .gr-grid {
    display: flex;
    gap: 20px;
    flex-shrink: 0;
    padding-right: 20px;
  }
  .gr-grid--clone { flex-shrink: 0; }

  /* Card */
  .gr-card {
    background: #f8f9fb;
    border: 1px solid #e8e8f0;
    border-radius: 20px;
    padding: 22px;
    display: flex;
    flex-direction: column;
    gap: 12px;
