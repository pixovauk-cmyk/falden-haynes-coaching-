          <span class="gr-sep">·</span>
          <span class="gr-stars-badge" aria-label="5 stars">★★★★★</span>
          <span class="gr-count">5 reviews · Feldon Haynes Coaching</span>
        </div>
      </div>
      <h2 class="gr-h2">{grH2}</h2>
      <p class="gr-sub">{grSub}</p>
    </div>

