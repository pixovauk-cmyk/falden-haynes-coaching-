---
import { reader } from '../lib/reader';

const ap    = await reader.singletons.about_page.read();
const site  = await reader.singletons.site_settings.read();
const grH2  = ap?.gr_h2  ?? 'What clients say on Google.';
const grSub = ap?.gr_sub ?? "Real feedback from people who've worked with Feldon directly.";
const googleUrl = site?.google_reviews_url ?? 'https://www.google.com/search?q=feldon+haynes+coaching';
