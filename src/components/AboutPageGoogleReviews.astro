          </svg>
          <span class="gr-badge-text">Google Reviews</span>
          <span class="gr-sep">·</span>
          <span class="gr-stars-badge" aria-label="5 stars">★★★★★</span>
          <span class="gr-count">5 reviews · Feldon Haynes Coaching</span>
        </div>
      </div>
      <h2 class="gr-h2">What clients say on Google.</h2>
      <p class="gr-sub">Real feedback from people who've worked with Feldon directly.</p>
    </div>

    <!-- Scroll wrapper: swipe on mobile, grid on desktop -->
    <div class="gr-scroll-wrap">
      <div class="gr-grid fade-in">

        <!-- 1. Mohamed Abdelrahim -->
        <article class="gr-card">
