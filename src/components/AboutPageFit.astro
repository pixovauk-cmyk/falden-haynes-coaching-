---
// AboutPageFit.astro — "Is this you?" editorial split layout
// Left: stacked photos from unused image library
// Right: 3 scenario statements + honest "not for you" strip
// Completely different from homepage ProblemGrid — conversational, personal
---

<section class="fit" aria-label="Who Feldon works with" id="who-i-work-with">
  <div class="container">

    <div class="fit-header fade-in">
      <p class="fit-eyebrow">
        <span class="eyebrow-line" aria-hidden="true"></span>
        The right fit
      </p>
      <h2 class="fit-h2">Is this you?</h2>
      <p class="fit-intro">
        I work with a small number of clients at a time. Here's who gets the most from working with me.
      </p>
    </div>

    <!-- Split layout: photos left, scenarios right -->
    <div class="fit-split fade-in">

      <!-- LEFT: photo stack -->
      <div class="fit-photos">
        <div class="fit-photo-main">
          <img
            src="/Images/1-1coaching.webp"
            alt="One-to-one coaching session"
            width="480"
            height="320"
            loading="lazy"
            class="fit-img fit-img--main"
          />
          <div class="fit-photo-chip">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.99 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.9 1.18h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 8.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            Wednesdays and Thursdays, 8am to 6pm
          </div>
        </div>
        <div class="fit-photo-pair">
          <img
            src="/Images/Businessplanning.webp"
            alt="Business planning session"
            width="220"
            height="220"
            loading="lazy"
            class="fit-img fit-img--sm"
          />
          <div class="fit-stat-card">
            <span class="fit-stat-num">40+</span>
            <span class="fit-stat-label">Founders supported</span>
          </div>
        </div>
      </div>

      <!-- RIGHT: scenarios -->
      <div class="fit-scenarios">

        <div class="fit-scenario">
          <div class="fit-check" aria-hidden="true">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
              <path d="M2.5 7l3 3 6-6" stroke="#534AB7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <div>
            <h3 class="fit-scenario-h3">You've got a business idea and you're serious about it.</h3>
            <p class="fit-scenario-body">
              You haven't launched yet but you're ready to. You need a structured plan,
              not more motivation. You're willing to do the work.
            </p>
          </div>
        </div>

        <div class="fit-divider" aria-hidden="true"></div>

        <div class="fit-scenario">
          <div class="fit-check" aria-hidden="true">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
              <path d="M2.5 7l3 3 6-6" stroke="#534AB7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <div>
            <h3 class="fit-scenario-h3">You're already running, under two years in, and something feels off.</h3>
            <p class="fit-scenario-body">
              You've got customers but you're growing in the wrong direction, or not
              growing at all. You need an outside perspective from someone who's actually
              operated businesses.
            </p>
          </div>
        </div>

        <div class="fit-divider" aria-hidden="true"></div>

        <div class="fit-scenario">
          <div class="fit-check" aria-hidden="true">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
              <path d="M2.5 7l3 3 6-6" stroke="#534AB7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <div>
            <h3 class="fit-scenario-h3">You lead an organisation with a specific challenge to solve.</h3>
            <p class="fit-scenario-body">
              A charity, social enterprise, or established business. A project to deliver.
              A pivot to navigate. You need focused, structured thinking from someone who
              gets the nuance.
            </p>
          </div>
        </div>

        <a
          href="https://calendly.com/feldeluxe/discovery-call"
          class="fit-cta"
          target="_blank"
          rel="noopener noreferrer"
        >
          Not sure? Book a free 30-minute call
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M2.5 7h9M8 3.5L11.5 7 8 10.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>

      </div>
    </div>

    <!-- "Not for you" strip -->
    <div class="not-fit fade-in">
      <div class="not-fit-icon" aria-hidden="true">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
        </svg>
      </div>
      <div>
        <p class="not-fit-heading">And honestly, not everyone is the right fit.</p>
        <p class="not-fit-body">
          If you want someone to do the thinking for you, guaranteed results without
          commitment, or validation without honesty, I'm not your coach. I'd rather
          tell you that upfront than waste both our time.
        </p>
      </div>
    </div>

  </div>
</section>

<style>
  .fit {
    background: #f8f9fb;
    padding: 80px 0;
  }

  /* Header */
  .fit-header {
    text-align: center;
    margin-bottom: 52px;
  }
  .fit-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #534AB7;
    margin-bottom: 14px;
  }
  .eyebrow-line {
    display: inline-block;
    width: 28px;
    height: 1px;
    background: #F2D832;
    flex-shrink: 0;
  }
  .fit-h2 {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 52px;
    font-weight: 800;
    letter-spacing: -0.03em;
    color: #1a1744;
    line-height: 1.05;
    margin-bottom: 14px;
  }
  .fit-intro {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 16px;
    font-weight: 400;
    color: #7e7a9f;
    max-width: 440px;
    margin: 0 auto;
    line-height: 1.7;
  }

  /* ── Split layout ────────────────────────── */
  .fit-split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: start;
    margin-bottom: 24px;
  }

  /* ── LEFT: photos ────────────────────────── */
  .fit-photos {
    display: flex;
    flex-direction: column;
    gap: 16px;
    position: sticky;
    top: 24px;
  }

  .fit-photo-main {
    position: relative;
    border-radius: 20px;
    overflow: hidden;
  }
  .fit-img--main {
    width: 100%;
    height: 280px;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }
  .fit-photo-main:hover .fit-img--main { transform: scale(1.03); }

  .fit-photo-chip {
    position: absolute;
    bottom: 16px;
    left: 16px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(255,255,255,0.95);
    color: #534AB7;
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 12px;
    font-weight: 600;
    padding: 8px 14px;
    border-radius: 9999px;
    box-shadow: 0 4px 16px rgba(0,0,0,0.12);
    backdrop-filter: blur(8px);
  }

  .fit-photo-pair {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .fit-img--sm {
    width: 100%;
    height: 160px;
    object-fit: cover;
    border-radius: 16px;
    display: block;
  }

  .fit-stat-card {
    background: #26215C;
    border-radius: 16px;
    padding: 24px 20px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 4px;
  }
  .fit-stat-num {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 40px;
    font-weight: 800;
    color: #F2D832;
    letter-spacing: -0.03em;
    line-height: 1;
  }
  .fit-stat-label {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 12px;
    font-weight: 500;
    color: rgba(175, 169, 236, 0.85);
    line-height: 1.4;
  }

  /* ── RIGHT: scenarios ────────────────────── */
  .fit-scenarios {
    display: flex;
    flex-direction: column;
    gap: 0;
    padding-top: 8px;
  }

  .fit-scenario {
    display: flex;
    gap: 16px;
    align-items: flex-start;
    padding: 24px 0;
  }

  .fit-check {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: #e3dfff;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .fit-scenario-h3 {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 18px;
    font-weight: 700;
    color: #1a1744;
    line-height: 1.3;
    margin-bottom: 10px;
  }

  .fit-scenario-body {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 14px;
    font-weight: 400;
    color: #7e7a9f;
    line-height: 1.75;
  }

  .fit-divider {
    height: 1px;
    background: #ede9ff;
    margin: 0;
  }

  .fit-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #534AB7;
    color: #ffffff;
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 15px;
    font-weight: 600;
    padding: 14px 28px;
    border-radius: 9999px;
    text-decoration: none;
    margin-top: 28px;
    align-self: flex-start;
    min-height: 50px;
    transition: background 0.2s, transform 0.1s;
  }
  .fit-cta:hover { background: #3b309e; }
  .fit-cta:active { transform: scale(0.98); }

  /* ── Not fit strip ───────────────────────── */
  .not-fit {
    display: flex;
    gap: 16px;
    align-items: flex-start;
    background: #ffffff;
    border: 1.5px solid #ede9ff;
    border-radius: 16px;
    padding: 24px 28px;
  }
  .not-fit-icon {
    width: 36px;
    height: 36px;
    min-width: 36px;
    background: #fff3f3;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #e55;
    margin-top: 2px;
    flex-shrink: 0;
  }
  .not-fit-heading {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 15px;
    font-weight: 700;
    color: #1a1744;
    margin-bottom: 6px;
  }
  .not-fit-body {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 14px;
    font-weight: 400;
    color: #7e7a9f;
    line-height: 1.75;
  }

  /* ── Tablet ──────────────────────────────── */
  @media (max-width: 1024px) {
    .fit-split { grid-template-columns: 1fr; gap: 40px; }
    .fit-photos { position: static; }
    .fit-img--main { height: 220px; }
    .fit-h2 { font-size: 38px; }
    .fit-scenario-h3 { font-size: 16px; }
  }

  /* ── Mobile ──────────────────────────────── */
  @media (max-width: 640px) {
    .fit { padding: 52px 0; }
    .fit-h2 { font-size: 30px; }
    .fit-header { margin-bottom: 36px; }
    .fit-photo-pair { grid-template-columns: 1fr 1fr; }
    .fit-img--sm { height: 120px; }
    .fit-stat-num { font-size: 32px; }
    .fit-cta { width: 100%; justify-content: center; }
    .not-fit { padding: 20px; }
  }
</style>
