<style>
  .marquee-section {
    background: #ffffff;
    padding: 40px 0 48px;
    overflow: hidden;
    border-bottom: 1px solid #f0eeff;
  }

  .marquee-header {
    text-align: center;
    margin-bottom: 28px;
  }

  .marquee-chip {
    display: inline-block;
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #534AB7;
    background: #EEEDFE;
    padding: 6px 18px;
    border-radius: 100px;
  }

  /* Scrolling container — masks overflow */
  .marquee-outer {
    overflow: hidden;
    /* Fade edges */
    -webkit-mask-image: linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%);
    mask-image: linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%);
  }

  /* The moving track — holds 2 sets of cards */
  .marquee-track {
    display: flex;
    gap: 16px;
    width: max-content;
    animation: marquee-scroll 36s linear infinite;
  }

  .marquee-track:hover {
    animation-play-state: paused;
  }

  @keyframes marquee-scroll {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  /* Individual card */
  .t-card {
    background: #ffffff;
    border: 1px solid #ece9fb;
    border-radius: 16px;
    padding: 20px 22px;
    width: 300px;
    flex-shrink: 0;
    box-shadow: 0 2px 16px rgba(38, 33, 92, 0.07);
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  /* Top row: avatar + name */
  .t-top {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .t-avatar {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid #EEEDFE;
    flex-shrink: 0;
    display: block;
  }

  .t-name {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 13px;
    font-weight: 600;
    color: #26215C;
    line-height: 1.3;
  }

  .t-role {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 11px;
    font-weight: 400;
    color: #AFA9EC;
    line-height: 1.3;
  }

  /* Stars */
  .t-stars {
    font-size: 13px;
    color: #F2D832;
    letter-spacing: 2px;
    line-height: 1;
  }

  /* Quote */
  .t-quote {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 12px;
    font-weight: 300;
    color: #555;
    line-height: 1.7;
  }

  /* Respect reduced-motion preference */
  @media (prefers-reduced-motion: reduce) {
    .marquee-track {
      animation: none;
      flex-wrap: wrap;
      width: 100%;
    }
    .marquee-outer {
      -webkit-mask-image: none;
      mask-image: none;
      padding: 0 20px;
    }
  }
</style>
