---
// AboutTeaser.astro — short about section on homepage
// Clean white background, 2-col: photo left (full bleed), text right
// No decorative dashes — chip tags only
---

<section class="about-teaser" aria-label="About Feldon Haynes">
  <div class="about-inner container">

    <!-- LEFT: photo -->
    <div class="about-photo-wrap fade-in">
      <div class="about-photo-card">
        <img
          src="/Images/feldon-haynes-professional-headshot.webp"
          alt="Professional headshot of Feldon Haynes business coach"
          width="520"
          height="600"
          loading="lazy"
          class="about-photo"
        />
        <!-- Award chip overlay -->
        <div class="about-award-chip" aria-hidden="true">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="8" r="6"/>
            <path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/>
          </svg>
          <span>3× Award winner</span>
        </div>
      </div>
    </div>

    <!-- RIGHT: text -->
    <div class="about-text fade-in">

      <span class="about-chip">About Feldon</span>

      <h2 class="about-h2">
        I've started 35 businesses.<br>
        Now I help you <em>build yours.</em>
      </h2>

      <p class="about-body">
        I know what it's like to have an idea you believe in and not know
        where to take it next. I've also built businesses from scratch.
        Made the mistakes, figured out what works, and come out the other
        side with something real.
      </p>
      <p class="about-body">
        That's what I bring to every session. Not theory. Not frameworks
        from a book. Real experience from someone who's been in the same
        position and found a way through.
      </p>

      <!-- Stats row -->
      <div class="about-stats">
        <div class="about-stat">
          <span class="about-stat-num">35+</span>
          <span class="about-stat-label">Businesses started</span>
        </div>
        <div class="about-stat-divider" aria-hidden="true"></div>
        <div class="about-stat">
          <span class="about-stat-num">40+</span>
          <span class="about-stat-label">Founders supported</span>
        </div>
        <div class="about-stat-divider" aria-hidden="true"></div>
        <div class="about-stat">
          <span class="about-stat-num">3×</span>
          <span class="about-stat-label">Industry awards</span>
        </div>
      </div>

      <div class="about-buttons">
        <a href="/about" class="btn-primary">Read my full story</a>
        <a
          href="https://calendly.com/feldeluxe/discovery-call"
          class="btn-ghost"
          target="_blank"
          rel="noopener noreferrer"
        >
          Book a free call
        </a>
      </div>

    </div>

  </div>
</section>

<style>
  .about-teaser {
    background: #ffffff;
    padding: 80px 0;
    overflow: hidden;
  }

  .about-inner {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 72px;
    align-items: center;
  }

  /* ── LEFT: photo ────────────────────────── */
  .about-photo-wrap {
    display: flex;
    justify-content: center;
  }

  .about-photo-card {
    position: relative;
    width: 100%;
    max-width: 420px;
  }

  .about-photo {
    width: 100%;
    height: 520px;
    object-fit: cover;
    object-position: center top;
    border-radius: 24px;
    display: block;
    box-shadow: 0 20px 60px rgba(59, 48, 158, 0.15);
  }

  .about-award-chip {
    position: absolute;
    bottom: 28px;
    left: -20px;
    background: #534ab7;
    color: #F2D832;
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 12px;
    font-weight: 700;
    padding: 10px 18px;
    border-radius: 9999px;
    display: flex;
    align-items: center;
    gap: 6px;
    box-shadow: 0 8px 24px rgba(83, 74, 183, 0.4);
  }

  /* ── RIGHT: text ────────────────────────── */
  .about-text {
    display: flex;
    flex-direction: column;
  }

  .about-chip {
    display: inline-flex;
    align-items: center;
    background: #e3dfff;
    color: #3b309e;
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 5px 14px;
    border-radius: 9999px;
    margin-bottom: 24px;
    align-self: flex-start;
  }

  .about-h2 {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 52px;
    font-weight: 800;
    letter-spacing: -0.03em;
    color: #1a1744;
    line-height: 1.1;
    margin-bottom: 28px;
  }
  .about-h2 em {
    font-style: italic;
    color: #534ab7;
    font-weight: 700;
  }

  .about-body {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 17px;
    font-weight: 400;
    color: #7e7a9f;
    line-height: 1.8;
    margin-bottom: 18px;
    max-width: 500px;
  }
  .about-body:last-of-type { margin-bottom: 0; }

  /* Stats row */
  .about-stats {
    display: flex;
    align-items: center;
    gap: 0;
    margin: 32px 0 36px;
    padding: 24px 0;
    border-top: 1px solid #f0eff8;
    border-bottom: 1px solid #f0eff8;
  }

  .about-stat {
    display: flex;
    flex-direction: column;
    gap: 2px;
    flex: 1;
    text-align: center;
  }

  .about-stat-divider {
    width: 1px;
    height: 32px;
    background: #ede9ff;
    flex-shrink: 0;
  }

  .about-stat-num {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 28px;
    font-weight: 800;
    color: #534ab7;
    letter-spacing: -0.02em;
    line-height: 1;
  }

  .about-stat-label {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 11px;
    font-weight: 500;
    color: #7e7a9f;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    line-height: 1.4;
  }

  /* Buttons */
  .about-buttons {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    background: #534ab7;
    color: #ffffff;
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 14px;
    font-weight: 600;
    padding: 13px 26px;
    border-radius: 9999px;
    white-space: nowrap;
    min-height: 48px;
    transition: background 0.2s ease, transform 0.1s ease;
  }
  .btn-primary:hover  { background: #3b309e; }
  .btn-primary:active { transform: scale(0.98); }

  .btn-ghost {
    display: inline-flex;
    align-items: center;
    background: transparent;
    color: #4a4670;
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 14px;
    font-weight: 500;
    padding: 13px 26px;
    border-radius: 9999px;
    border: 1.5px solid #d5d2ea;
    white-space: nowrap;
    min-height: 48px;
    transition: border-color 0.2s ease, color 0.2s ease, background 0.2s ease;
  }
  .btn-ghost:hover {
    border-color: #534ab7;
    color: #534ab7;
    background: #f0eeff;
  }

  /* ── Mobile ─────────────────────────────── */
  @media (max-width: 1024px) {
    .about-inner {
      gap: 48px;
    }
    .about-h2 { font-size: 32px; }
  }

  @media (max-width: 768px) {
    .about-teaser { padding: 52px 0; }
    .about-inner {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .about-photo-wrap {
      order: -1;
    }
    .about-photo { height: 320px; }
    .about-h2 { font-size: 28px; }
    .about-buttons {
      flex-direction: column;
    }
    .btn-primary,
    .btn-ghost {
      text-align: center;
      justify-content: center;
      width: 100%;
    }
  }
</style>
