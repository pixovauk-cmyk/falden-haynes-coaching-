---
// CookieBanner.astro — GDPR cookie consent (accept/decline)
// Replace GA4_ID below with your G-XXXXXXXXXX measurement ID when available
---

<div
  id="cookie-banner"
  role="dialog"
  aria-label="Cookie consent"
  aria-live="polite"
  hidden
>
  <div class="cookie-inner">
    <p class="cookie-text">
      We use cookies to understand how visitors use our site and to improve your experience.
      Read our <a href="/privacy">Privacy Policy</a>.
    </p>
    <div class="cookie-actions">
      <button id="cookie-decline" class="cookie-btn cookie-btn--secondary">Decline</button>
      <button id="cookie-accept" class="cookie-btn cookie-btn--primary">Accept all</button>
    </div>
  </div>
</div>

<script>
  const CONSENT_KEY = 'fh_cookie_consent';
  const GA4_ID = 'G-9CHPL1FWHG';

  function loadGA4() {
    if (document.getElementById('ga4-script')) return;
    const script = document.createElement('script');
    script.id = 'ga4-script';
    script.async = true;
    script.src = `https://www.googletagmanager.com/gtag/js?id=${GA4_ID}`;
    document.head.appendChild(script);
    (window as any).dataLayer = (window as any).dataLayer || [];
    function gtag(...args: any[]) { (window as any).dataLayer.push(args); }
    gtag('js', new Date());
    gtag('config', GA4_ID);
  }

  function setWAOffset(px: number) {
    document.documentElement.style.setProperty('--cookie-offset', `${px}px`);
  }

  function hideBanner() {
    const banner = document.getElementById('cookie-banner');
    if (banner) banner.hidden = true;
    setWAOffset(0);
  }

  function showBanner() {
    const banner = document.getElementById('cookie-banner') as HTMLElement | null;
    if (!banner) return;
    banner.hidden = false;
    // Defer so browser has painted and offsetHeight is accurate
    requestAnimationFrame(() => setWAOffset(banner.offsetHeight));
  }

  const stored = localStorage.getItem(CONSENT_KEY);

  if (stored === 'accepted') {
    loadGA4();
  } else if (!stored) {
    showBanner();
    window.addEventListener('resize', () => {
      const banner = document.getElementById('cookie-banner') as HTMLElement | null;
      if (banner && !banner.hidden) setWAOffset(banner.offsetHeight);
    });
  }

  document.getElementById('cookie-accept')?.addEventListener('click', () => {
    localStorage.setItem(CONSENT_KEY, 'accepted');
    hideBanner();
    loadGA4();
  });

  document.getElementById('cookie-decline')?.addEventListener('click', () => {
    localStorage.setItem(CONSENT_KEY, 'declined');
    hideBanner();
  });
</script>

<style>
  #cookie-banner {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 10000;
    background: var(--navy);
    color: #ffffff;
    padding: 18px 24px;
    box-shadow: 0 -4px 24px rgba(26, 23, 68, 0.18);
  }

  .cookie-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 24px;
    flex-wrap: wrap;
  }

  .cookie-text {
    flex: 1;
    font-family: var(--font-sans);
    font-size: 14px;
    line-height: 1.55;
    color: rgba(255, 255, 255, 0.85);
    margin: 0;
  }

  .cookie-text a {
    color: var(--gold);
    text-underline-offset: 3px;
  }

  .cookie-actions {
    display: flex;
    gap: 10px;
    flex-shrink: 0;
  }

  .cookie-btn {
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 600;
    padding: 10px 22px;
    border-radius: var(--radius-full);
    border: none;
    cursor: pointer;
    transition: opacity 0.2s, transform 0.15s;
    white-space: nowrap;
  }

  .cookie-btn:hover  { opacity: 0.88; transform: translateY(-1px); }
  .cookie-btn:active { transform: scale(0.97); }

  .cookie-btn--primary {
    background: var(--gold);
    color: var(--navy);
  }

  .cookie-btn--secondary {
    background: transparent;
    color: #ffffff;
    border: 1.5px solid rgba(255, 255, 255, 0.32);
  }

  @media (max-width: 600px) {
    .cookie-inner  { flex-direction: column; align-items: flex-start; gap: 14px; }
    .cookie-actions { width: 100%; }
    .cookie-btn    { flex: 1; text-align: center; }
  }
</style>
