---
// StatsStrip.astro — social proof credentials bar
// Background: #534AB7 purple — gold numbers, white labels
---

<section class="stats" aria-label="Key credentials">
  <div class="container">
    <div class="stats-inner">

      <div class="stat">
        <span class="stat-number">35+</span>
        <span class="stat-label">Businesses started</span>
      </div>

      <div class="stat-divider" aria-hidden="true"></div>

      <div class="stat">
        <span class="stat-number">40+</span>
        <span class="stat-label">Founders supported</span>
      </div>

      <div class="stat-divider" aria-hidden="true"></div>

      <div class="stat">
        <span class="stat-number">3&times;</span>
        <span class="stat-label">Industry awards</span>
      </div>

      <div class="stat-divider" aria-hidden="true"></div>

      <div class="stat">
        <span class="stat-number stat-number--sm">EPIC</span>
        <span class="stat-label">Spirit Award winner</span>
      </div>

    </div>
  </div>
</section>

<style>
  .stats {
    background: #534AB7;
    padding: 0;
  }

  .stats-inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
    padding: 24px 0;
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    text-align: center;
    flex: 1;
    padding: 16px 24px;
  }

  .stat-divider {
    width: 1px;
    height: 40px;
    background: rgba(255, 255, 255, 0.1);
    flex-shrink: 0;
  }

  .stat-number {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 32px;
    font-weight: 700;
    color: #F2D832;
    line-height: 1;
  }

  .stat-number--sm {
    font-size: 26px;
  }

  .stat-label {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.3;
  }

  /* ── Tablet ──────────────────────────────── */
  @media (max-width: 900px) {
    .stat-number { font-size: 26px; }
    .stat-number--sm { font-size: 22px; }
    .stat { padding: 16px 16px; }
  }

  /* ── Mobile ─────────────────────────────── */
  @media (max-width: 600px) {
    .stats-inner {
      flex-wrap: wrap;
      gap: 0;
      padding: 16px 0;
    }
    .stat {
      width: 50%;
      flex: none;
      padding: 16px 12px;
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    }
    .stat:nth-child(odd) { border-right: 1px solid rgba(255, 255, 255, 0.08); }
    .stat:nth-last-child(-n+2) { border-bottom: none; }
    .stat-divider { display: none; }
    .stat-number { font-size: 24px; }
    .stat-number--sm { font-size: 20px; }
  }
</style>
