---
// BundleCards.astro — 4-col pricing grid
// Background: #ffffff clean white
// Most Popular = Business Plan Bundle — outlined ring treatment
---

<section class="bundles" id="services" aria-label="Coaching bundles">
  <div class="container">

    <div class="bundles-header fade-in">
      <span class="b-chip">Investment bundles</span>
      <h2 class="b-h2">Choose your starting point</h2>
      <p class="b-intro">
        Launch pricing. All sessions online, Wednesdays and Thursdays, 8am to 6pm.
      </p>
    </div>

    <div class="bundles-scroll-wrap" id="bundles-scroll">
    <div class="bundles-grid fade-in">

      <!-- Bundle 1: Project Bundle -->
      <article class="bundle-card" aria-label="The Project Bundle">

        <div class="bundle-icon" aria-hidden="true">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="9 11 12 14 22 4"/>
            <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>
          </svg>
        </div>

        <h3 class="bundle-name">The Project Bundle</h3>
        <p class="bundle-meta">3 sessions &middot; Specific project</p>

        <div class="bundle-price-row">
          <span class="bundle-price">&pound;90</span>
          <span class="bundle-was">&pound;150</span>
          <span class="bundle-save">Save £60</span>
        </div>

        <p class="bundle-desc">
          Three focused sessions to scope, map, and launch a specific project.
        </p>

        <a
          href="https://calendly.com/feldeluxe/packages/da7fbbe4-840c-4ea8-8147-2128f99cfd6b"
          class="bundle-btn bundle-btn--ghost"
          target="_blank"
          rel="noopener noreferrer"
        >Select bundle</a>
      </article>

      <!-- Bundle 2: Action Sprint Bundle -->
      <article class="bundle-card" aria-label="The Action Sprint Bundle">

        <div class="bundle-icon" aria-hidden="true">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
          </svg>
        </div>

        <h3 class="bundle-name">The Action Sprint Bundle</h3>
        <p class="bundle-meta">3 sessions &middot; Stuck founders</p>

        <div class="bundle-price-row">
          <span class="bundle-price">&pound;90</span>
          <span class="bundle-was">&pound;150</span>
          <span class="bundle-save">Save £60</span>
        </div>

        <p class="bundle-desc">
          Find the block, make the decision, and build a 30-day plan to move fast.
        </p>

        <a
          href="https://calendly.com/feldeluxe/packages/549dd535-e12c-4506-822a-9a839af25318"
          class="bundle-btn bundle-btn--ghost"
          target="_blank"
          rel="noopener noreferrer"
        >Select bundle</a>
      </article>

      <!-- Bundle 3: Business Plan Bundle — MOST POPULAR -->
      <article class="bundle-card bundle-card--popular" aria-label="The Business Plan Bundle — Most Popular">
        <div class="bundle-badge">Most Popular</div>

        <div class="bundle-icon" aria-hidden="true">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14 3v4a1 1 0 0 0 1 1h4"/>
            <path d="M17 21H7a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h7l5 5v11a2 2 0 0 1-2 2z"/>
            <line x1="9" y1="13" x2="15" y2="13"/>
            <line x1="9" y1="17" x2="15" y2="17"/>
          </svg>
        </div>

        <h3 class="bundle-name">The Business Plan Bundle</h3>
        <p class="bundle-meta">6 sessions &middot; Aspiring founders</p>

        <div class="bundle-price-row">
          <span class="bundle-price">&pound;160</span>
          <span class="bundle-was">&pound;300</span>
          <span class="bundle-save">Save £140</span>
        </div>

        <p class="bundle-desc">
          From idea to a complete, executable plan. Validated, structured, and ready to launch.
        </p>

        <a
          href="https://calendly.com/feldeluxe/packages/8af8f4b4-b4fc-4b38-a4d7-4c8863f57ce5"
          class="bundle-btn bundle-btn--filled"
          target="_blank"
          rel="noopener noreferrer"
        >Select bundle</a>
      </article>

      <!-- Bundle 4: Direction Bundle -->
      <article class="bundle-card" aria-label="The Direction Bundle">

        <div class="bundle-icon" aria-hidden="true">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"/>
          </svg>
        </div>

        <h3 class="bundle-name">The Direction Bundle</h3>
        <p class="bundle-meta">6 sessions &middot; Lost direction</p>

        <div class="bundle-price-row">
          <span class="bundle-price">&pound;160</span>
          <span class="bundle-was">&pound;300</span>
          <span class="bundle-save">Save £140</span>
        </div>

        <p class="bundle-desc">
          Business audit, vision work, and a 6-month strategic roadmap for existing businesses.
        </p>

        <a
          href="https://calendly.com/feldeluxe/packages/bcd3e931-3e20-4faa-9d96-2a82cc4e121a"
          class="bundle-btn bundle-btn--ghost"
          target="_blank"
          rel="noopener noreferrer"
        >Select bundle</a>
      </article>

    </div>
    </div>

    <!-- Mobile carousel nav -->
    <div class="bundles-carousel-nav" aria-label="Scroll bundles">
      <button class="bundles-carousel-btn" id="bundles-prev" aria-label="Previous">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true"><path d="M11 4L6 9l5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
      <button class="bundles-carousel-btn" id="bundles-next" aria-label="Next">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true"><path d="M7 4l5 5-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
    </div>

    <p class="bundles-note fade-in">
      Not sure which fits?&nbsp;
      <a href="https://calendly.com/feldeluxe/discovery-call" class="bundles-note-link" target="_blank" rel="noopener noreferrer">
        Start with a free 30-minute discovery call &rarr;
      </a>
    </p>

  </div>
</section>

<style>
  .bundles {
    background: #f0eff8;
    padding: 80px 0;
  }

  /* Header */
  .bundles-header {
    margin-bottom: 48px;
    text-align: center;
  }

  .b-chip {
    display: inline-flex;
    align-items: center;
    background: #e3dfff;
    color: #3b309e;
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 7px 18px;
    border-radius: 9999px;
    margin-bottom: 24px;
  }

  .b-h2 {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 52px;
    font-weight: 800;
    letter-spacing: -0.03em;
    color: #1a1744;
    margin-bottom: 16px;
    line-height: 1.1;
  }

  .b-intro {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 18px;
    font-weight: 400;
    color: #7e7a9f;
    line-height: 1.7;
  }

  /* ── 4-col grid ─────────────────────────── */
  .bundles-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    margin-bottom: 36px;
  }

  /* Base card */
  .bundle-card {
    position: relative;
    background: #f8f9fb;
    border-radius: 20px;
    border: 1.5px solid #ede9ff;
    padding: 28px 24px 24px;
    box-shadow: 0 4px 20px rgba(59, 48, 158, 0.06);
    display: flex;
    flex-direction: column;
    transition: transform 0.22s ease, box-shadow 0.22s ease;
  }
  .bundle-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 48px rgba(59, 48, 158, 0.12);
  }

  /* Most popular — ring treatment */
  .bundle-card--popular {
    background: #ffffff;
    border: 2.5px solid #534ab7;
    box-shadow: 0 0 0 4px rgba(83, 74, 183, 0.1), 0 8px 32px rgba(59, 48, 158, 0.12);
  }
  .bundle-card--popular:hover {
    box-shadow: 0 0 0 4px rgba(83, 74, 183, 0.15), 0 20px 56px rgba(59, 48, 158, 0.18);
  }

  /* Icon */
  .bundle-icon {
    width: 44px;
    height: 44px;
    background: #e3dfff;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #534ab7;
    margin-bottom: 40px;
    flex-shrink: 0;
  }
  .bundle-card--popular .bundle-icon {
    background: #534ab7;
    color: #ffffff;
  }

  /* Most Popular badge */
  .bundle-badge {
    position: absolute;
    top: -13px;
    left: 50%;
    transform: translateX(-50%);
    background: #534ab7;
    color: #F2D832;
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 4px 16px;
    border-radius: 9999px;
    white-space: nowrap;
  }

  .bundle-name {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 18px;
    font-weight: 700;
    color: #1a1744;
    line-height: 1.3;
    margin-bottom: 6px;
  }

  .bundle-meta {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 14px;
    font-weight: 400;
    color: #7e7a9f;
    margin-bottom: 20px;
  }

  /* Price row */
  .bundle-price-row {
    display: flex;
    align-items: baseline;
    gap: 8px;
    margin-bottom: 16px;
    flex-wrap: wrap;
  }

  .bundle-price {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 42px;
    font-weight: 800;
    color: #534ab7;
    line-height: 1;
    letter-spacing: -0.02em;
  }

  .bundle-was {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 14px;
    font-weight: 400;
    color: #c4bfe0;
    text-decoration: line-through;
  }

  .bundle-save {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 11px;
    font-weight: 600;
    color: #065f3c;
    background: #e3f5ec;
    padding: 3px 9px;
    border-radius: 9999px;
  }

  .bundle-desc {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 15px;
    font-weight: 400;
    color: #7e7a9f;
    line-height: 1.7;
    flex: 1;
    margin-bottom: 24px;
  }

  /* CTA buttons */
  .bundle-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 15px;
    font-weight: 600;
    padding: 14px;
    border-radius: 9999px;
    white-space: nowrap;
    min-height: 52px;
    transition: background 0.2s ease, border-color 0.2s ease, color 0.2s ease, transform 0.1s ease;
  }

  .bundle-btn--filled {
    background: #534ab7;
    color: #ffffff;
    border: 1.5px solid transparent;
  }
  .bundle-btn--filled:hover { background: #3b309e; }

  .bundle-btn--ghost {
    background: transparent;
    color: #534ab7;
    border: 1.5px solid #534ab7;
  }
  .bundle-btn--ghost:hover {
    background: #534ab7;
    color: #ffffff;
  }

  /* Below note */
  .bundles-note {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 14px;
    font-weight: 400;
    color: #7e7a9f;
    text-align: center;
  }
  .bundles-note-link {
    color: #534ab7;
    font-weight: 600;
    transition: color 0.2s ease;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .bundles-note-link:hover { color: #3b309e; }

  /* ── Tablet ──────────────────────────────── */
  @media (max-width: 1024px) {
    .bundles-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* Carousel nav — hidden on desktop */
  .bundles-carousel-nav {
    display: none;
    justify-content: center;
    gap: 12px;
    margin-top: 20px;
    margin-bottom: 8px;
  }
  .bundles-carousel-btn {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: #534AB7;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #ffffff;
    transition: background 0.2s, transform 0.1s;
    flex-shrink: 0;
  }
  .bundles-carousel-btn:hover { background: #3b309e; }
  .bundles-carousel-btn:active { transform: scale(0.95); }

  /* ── Mobile ─────────────────────────────── */
  @media (max-width: 640px) {
    .bundles { padding: 56px 0; }
    .b-h2 { font-size: 28px; }

    .bundles-scroll-wrap {
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      scrollbar-width: none;
      -ms-overflow-style: none;
      margin: 0 -16px;
      padding: 20px 16px 4px;
    }
    .bundles-scroll-wrap::-webkit-scrollbar { display: none; }

    .bundles-grid {
      display: flex;
      flex-wrap: nowrap;
      width: max-content;
      gap: 14px;
    }

    .bundle-card {
      width: calc(82vw);
      flex-shrink: 0;
      scroll-snap-align: start;
    }

    .bundles-carousel-nav { display: flex; }
  }
</style>

<script>
  const bWrap = document.getElementById('bundles-scroll');
  const bPrev = document.getElementById('bundles-prev');
  const bNext = document.getElementById('bundles-next');
  if (bWrap && bPrev && bNext) {
    const step = () => { const c = bWrap.querySelector('.bundle-card'); return c ? c.offsetWidth + 14 : 300; };
    bPrev.addEventListener('click', () => bWrap.scrollBy({ left: -step(), behavior: 'smooth' }));
    bNext.addEventListener('click', () => bWrap.scrollBy({ left: step(), behavior: 'smooth' }));
  }
</script>
