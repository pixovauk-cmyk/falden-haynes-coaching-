---
import { reader } from '../lib/reader';

const hp   = await reader.singletons.homepage.read();
const site = await reader.singletons.site_settings.read();

const sectionChip  = hp?.bundles_chip  ?? 'Investment bundles';
const sectionH2    = hp?.bundles_h2    ?? 'Choose your starting point';
const sectionIntro = hp?.bundles_intro ?? 'Launch pricing. All sessions online, Wednesdays and Thursdays, 8am to 6pm.';
const calendly     = site?.calendly_discovery ?? 'https://calendly.com/feldon-haynes/discovery-call';

// Read bundles collection and sort by sort_order
const rawBundles = await reader.collections.bundles.all();
const bundles = rawBundles
  .filter(b => b.entry != null)
  .sort((a, b) => (a.entry.sort_order ?? 99) - (b.entry.sort_order ?? 99));

// Fallback hardcoded bundles if collection is empty
const fallbackBundles = [
  {
    slug: 'the-project-bundle',
    name: 'The Project Bundle',
    tagline: 'Specific project',
    sessions: 3,
    price: 90,
    price_was: 150,
    description: 'Three focused sessions to scope, map, and launch a specific project.',
    calendly_url: site?.calendly_bundle_starter ?? 'https://calendly.com/feldon-haynes/packages/da7fbbe4-840c-4ea8-8147-2128f99cfd6b',
    most_popular: false,
  },
  {
    slug: 'the-action-sprint-bundle',
    name: 'The Action Sprint Bundle',
    tagline: 'Stuck founders',
    sessions: 3,
    price: 90,
    price_was: 150,
    description: 'Find the block, make the decision, and build a 30-day plan to move fast.',
    calendly_url: site?.calendly_bundle_foundation ?? 'https://calendly.com/feldon-haynes/packages/549dd535-e12c-4506-822a-9a839af25318',
    most_popular: false,
  },
  {
    slug: 'the-business-plan-bundle',
    name: 'The Business Plan Bundle',
    tagline: 'Aspiring founders',
    sessions: 6,
    price: 160,
    price_was: 300,
    description: 'From idea to a complete, executable plan. Validated, structured, and ready to launch.',
    calendly_url: site?.calendly_bundle_action ?? 'https://calendly.com/feldon-haynes/packages/8af8f4b4-b4fc-4b38-a4d7-4c8863f57ce5',
    most_popular: true,
  },
  {
    slug: 'the-direction-bundle',
    name: 'The Direction Bundle',
    tagline: 'Lost direction',
    sessions: 6,
    price: 160,
    price_was: 300,
    description: 'Business audit, vision work, and a 6-month strategic roadmap for existing businesses.',
    calendly_url: site?.calendly_bundle_full ?? 'https://calendly.com/feldon-haynes/packages/bcd3e931-3e20-4faa-9d96-2a82cc4e121a',
    most_popular: false,
  },
];

type BundleItem = {
  slug: string;
  name: string;
  tagline: string;
  sessions: number;
  price: number;
  price_was: number;
  description: string;
  calendly_url: string;
  most_popular: boolean;
};

const displayBundles: BundleItem[] = bundles.length > 0
  ? bundles.map(b => ({
      slug: b.slug,
      name: (b.entry.name as any)?.name ?? (b.entry.name as any) ?? b.slug,
      tagline: b.entry.tagline ?? '',
      sessions: b.entry.sessions ?? 0,
      price: b.entry.price ?? 0,
      price_was: b.entry.price_was ?? 0,
      description: b.entry.description ?? '',
      calendly_url: b.entry.calendly_url ?? calendly,
      most_popular: b.entry.most_popular ?? false,
    }))
  : fallbackBundles;

function savingsAmount(price: number, pricewas: number) {
  return pricewas - price;
}
---

<section class="bundles" id="services" aria-label="Coaching bundles">
  <div class="container">

    <div class="bundles-header fade-in">
      <span class="b-chip">{sectionChip}</span>
      <h2 class="b-h2">{sectionH2}</h2>
      <p class="b-intro">{sectionIntro}</p>
    </div>

    <div class="bundles-scroll-wrap" id="bundles-scroll">
    <div class="bundles-grid fade-in">

      {displayBundles.map((bundle, i) => (
        <article
          class={`bundle-card${bundle.most_popular ? ' bundle-card--popular' : ''}`}
          aria-label={`${bundle.name}${bundle.most_popular ? ' — Most Popular' : ''}`}
        >
          {bundle.most_popular && <div class="bundle-badge">Most Popular</div>}

          <div class="bundle-icon" aria-hidden="true">
            {(i % 4 === 0) && (
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="9 11 12 14 22 4"/>
                <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>
              </svg>
            )}
            {(i % 4 === 1) && (
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
              </svg>
            )}
            {(i % 4 === 2) && (
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M14 3v4a1 1 0 0 0 1 1h4"/>
                <path d="M17 21H7a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h7l5 5v11a2 2 0 0 1-2 2z"/>
                <line x1="9" y1="13" x2="15" y2="13"/>
                <line x1="9" y1="17" x2="15" y2="17"/>
              </svg>
            )}
            {(i % 4 === 3) && (
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
                <polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"/>
              </svg>
            )}
          </div>

          <h3 class="bundle-name">{bundle.name}</h3>
          <p class="bundle-meta">{bundle.sessions} sessions &middot; {bundle.tagline}</p>

          <div class="bundle-price-row">
            <span class="bundle-price">&pound;{bundle.price}</span>
            <span class="bundle-was">&pound;{bundle.price_was}</span>
            <span class="bundle-save">Save &pound;{savingsAmount(bundle.price, bundle.price_was)}</span>
          </div>

          <p class="bundle-desc">{bundle.description}</p>

          <a
            href={bundle.calendly_url}
            class={`bundle-btn ${bundle.most_popular ? 'bundle-btn--filled' : 'bundle-btn--ghost'}`}
            target="_blank"
            rel="noopener noreferrer"
          >Select bundle</a>
        </article>
      ))}

    </div>
    </div>

    <!-- Mobile carousel nav -->
    <div class="bundles-carousel-nav" aria-label="Scroll bundles">
      <button class="bundles-carousel-btn" id="bundles-prev" aria-label="Previous">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true"><path d="M11 4L6 9l5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
      <button class="bundles-carousel-btn" id="bundles-next" aria-label="Next">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true"><path d="M7 4l5 5-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
    </div>

    <p class="bundles-note fade-in">
      Not sure which fits?&nbsp;
      <a href={calendly} class="bundles-note-link" target="_blank" rel="noopener noreferrer">
        Start with a free 30-minute discovery call &rarr;
      </a>
    </p>

  </div>
</section>

<style>
  .bundles {
    background: #f0eff8;
    padding: 80px 0;
  }

  /* Header */
  .bundles-header {
    margin-bottom: 48px;
    text-align: center;
  }

  .b-chip {
    display: inline-flex;
    align-items: center;
    background: #e3dfff;
    color: #3b309e;
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 7px 18px;
    border-radius: 9999px;
    margin-bottom: 24px;
  }

  .b-h2 {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 52px;
    font-weight: 800;
    letter-spacing: -0.03em;
    color: #1a1744;
    margin-bottom: 16px;
    line-height: 1.1;
  }

  .b-intro {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 18px;
    font-weight: 400;
    color: #7e7a9f;
    line-height: 1.7;
  }

  /* ── Flex row — centres when ≤4 cards fit, scrolls when more ── */
  .bundles-scroll-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding-top: 20px;
    padding-bottom: 8px;
  }
  .bundles-scroll-wrap::-webkit-scrollbar { display: none; }

  .bundles-grid {
    display: flex;
    flex-wrap: nowrap;
    gap: 16px;
    width: max-content;
    margin: 0 auto 36px;
  }

  /* Base card */
  .bundle-card {
    position: relative;
    background: #f8f9fb;
    border-radius: 20px;
    border: 1.5px solid #ede9ff;
    padding: 28px 24px 24px;
    box-shadow: 0 4px 20px rgba(59, 48, 158, 0.06);
    display: flex;
    flex-direction: column;
    transition: transform 0.22s ease, box-shadow 0.22s ease;
    width: 272px;
    flex-shrink: 0;
    scroll-snap-align: start;
  }
  .bundle-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 48px rgba(59, 48, 158, 0.12);
  }

  /* Most popular — ring treatment */
  .bundle-card--popular {
    background: #ffffff;
    border: 2.5px solid #534ab7;
    box-shadow: 0 0 0 4px rgba(83, 74, 183, 0.1), 0 8px 32px rgba(59, 48, 158, 0.12);
  }
  .bundle-card--popular:hover {
    box-shadow: 0 0 0 4px rgba(83, 74, 183, 0.15), 0 20px 56px rgba(59, 48, 158, 0.18);
  }

  /* Icon */
  .bundle-icon {
    width: 44px;
    height: 44px;
    background: #e3dfff;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #534ab7;
    margin-bottom: 40px;
    flex-shrink: 0;
  }
  .bundle-card--popular .bundle-icon {
    background: #534ab7;
    color: #ffffff;
  }

  /* Most Popular badge */
  .bundle-badge {
    position: absolute;
    top: -13px;
    left: 50%;
    transform: translateX(-50%);
    background: #534ab7;
    color: #F2D832;
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 4px 16px;
    border-radius: 9999px;
    white-space: nowrap;
  }

  .bundle-name {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 18px;
    font-weight: 700;
    color: #1a1744;
    line-height: 1.3;
    margin-bottom: 6px;
  }

  .bundle-meta {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 14px;
    font-weight: 400;
    color: #7e7a9f;
    margin-bottom: 20px;
  }

  /* Price row */
  .bundle-price-row {
    display: flex;
    align-items: baseline;
    gap: 8px;
    margin-bottom: 16px;
    flex-wrap: wrap;
  }

  .bundle-price {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 42px;
    font-weight: 800;
    color: #534ab7;
    line-height: 1;
    letter-spacing: -0.02em;
  }

  .bundle-was {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 14px;
    font-weight: 400;
    color: #c4bfe0;
    text-decoration: line-through;
  }

  .bundle-save {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 11px;
    font-weight: 600;
    color: #065f3c;
    background: #e3f5ec;
    padding: 3px 9px;
    border-radius: 9999px;
  }

  .bundle-desc {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 15px;
    font-weight: 400;
    color: #7e7a9f;
    line-height: 1.7;
    flex: 1;
    margin-bottom: 24px;
  }

  /* CTA buttons */
  .bundle-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 15px;
    font-weight: 600;
    padding: 14px;
    border-radius: 9999px;
    white-space: nowrap;
    min-height: 52px;
    transition: background 0.2s ease, border-color 0.2s ease, color 0.2s ease, transform 0.1s ease;
  }

  .bundle-btn--filled {
    background: #534ab7;
    color: #ffffff;
    border: 1.5px solid transparent;
  }
  .bundle-btn--filled:hover { background: #3b309e; }

  .bundle-btn--ghost {
    background: transparent;
    color: #534ab7;
    border: 1.5px solid #534ab7;
  }
  .bundle-btn--ghost:hover {
    background: #534ab7;
    color: #ffffff;
  }

  /* Below note */
  .bundles-note {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 14px;
    font-weight: 400;
    color: #7e7a9f;
    text-align: center;
  }
  .bundles-note-link {
    color: #534ab7;
    font-weight: 600;
    transition: color 0.2s ease;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .bundles-note-link:hover { color: #3b309e; }

  /* Carousel nav — hidden on desktop */
  .bundles-carousel-nav {
    display: none;
    justify-content: center;
    gap: 12px;
    margin-top: 20px;
    margin-bottom: 8px;
  }
  .bundles-carousel-btn {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: #534AB7;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #ffffff;
    transition: background 0.2s, transform 0.1s;
    flex-shrink: 0;
  }
  .bundles-carousel-btn:hover { background: #3b309e; }
  .bundles-carousel-btn:active { transform: scale(0.95); }

  /* ── Tablet / Mobile ─────────────────────── */
  @media (max-width: 900px) {
    .bundles-scroll-wrap {
      margin: 0 -16px;
      padding: 20px 16px 4px;
    }
    .bundles-carousel-nav { display: flex; }
  }

  @media (max-width: 640px) {
    .bundles { padding: 56px 0; }
    .b-h2 { font-size: 28px; }
    .bundle-card { width: calc(82vw); }
  }
</style>

<script>
  const bWrap = document.getElementById('bundles-scroll');
  const bPrev = document.getElementById('bundles-prev');
  const bNext = document.getElementById('bundles-next');
  if (bWrap && bPrev && bNext) {
    const step = () => { const c = bWrap.querySelector('.bundle-card'); return c ? c.offsetWidth + 14 : 300; };
    bPrev.addEventListener('click', () => bWrap.scrollBy({ left: -step(), behavior: 'smooth' }));
    bNext.addEventListener('click', () => bWrap.scrollBy({ left: step(), behavior: 'smooth' }));
  }
</script>
