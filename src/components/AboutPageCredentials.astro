---
// AboutPageCredentials.astro — awards + community proof
// Redesigned: award card + community logos strip
// Background: #EEEDFE (lavender)
---

<section class="credentials" aria-label="Credentials and awards">
  <div class="container">

    <div class="cred-header fade-in">
      <p class="eyebrow">
        <span class="eyebrow-line" aria-hidden="true"></span>
        Why trust me
      </p>
      <h2 class="cred-h2">Real experience.<br>Real recognition.</h2>
      <p class="cred-intro">
        Here's what I've built and earned. And what it means for the founders I work with.
      </p>
    </div>

    <!-- Main award card: image left, content right -->
    <div class="award-card fade-in">

      <div class="award-img-col">
        <img
          src="/Images/feldon-haynes-award-photo.webp"
          alt="Feldon Haynes receiving an award for entrepreneurial achievement"
          width="560"
          height="580"
          loading="lazy"
          class="award-img"
        />
      </div>

      <div class="award-content-col">

        <div class="award-badge">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
          </svg>
          EPIC Spirit Award
        </div>

        <h3 class="award-h3">
          Awarded for entrepreneurial perseverance.
        </h3>

        <p class="award-body">
          The EPIC Spirit Award recognises founders who keep building through real
          adversity. Not the overnight success stories. The ones who hit genuine
          setbacks and pushed through anyway.
        </p>
        <p class="award-body">
          It's the most personally meaningful recognition I've received. Because it's
          about character, not just revenue.
        </p>

        <!-- Pull quote -->
        <blockquote class="award-pullquote">
          <span class="pq-mark" aria-hidden="true">"</span>
          <p class="pq-text">
            My mum always told me: my smile is my biggest selling point.
          </p>
        </blockquote>

        <!-- Award graphic -->
        <div class="award-graphic-wrap">
          <img
            src="/Images/Award.webp"
            alt="EPIC Spirit Award graphic"
            loading="lazy"
            width="360"
            height="360"
            class="award-graphic"
          />
        </div>

      </div>
    </div>

    <!-- Trusted by strip -->
    <div class="trusted-strip fade-in">

      <!-- Label -->
      <p class="trusted-label">Trusted by</p>

      <!-- NGH logo -->
      <a
        href="https://www.nextgenerationhub.com/"
        target="_blank"
        rel="noopener noreferrer"
        class="trusted-brand"
        aria-label="Next Generation Hub (opens in new tab)"
      >
        <img
          src="/Images/next-generation-hub-logo.png"
          alt="Next Generation Hub"
          width="160"
          height="52"
          loading="lazy"
          class="trusted-logo"
        />
      </a>

      <!-- Divider -->
      <div class="trusted-divider" aria-hidden="true"></div>

      <!-- Active in chips -->
      <div class="trusted-also">
        <span class="trusted-also-label">Also active in</span>
        <div class="trusted-chips">
          <span class="trusted-chip">Black Country Chamber of Commerce</span>
          <span class="trusted-chip">University of Warwick Science Park</span>
          <span class="trusted-chip">Young Leaders Club</span>
        </div>
      </div>

    </div>

  </div>
</section>

<style>
  .credentials {
    background: #EEEDFE;
    padding: 80px 0;
  }

  /* Header */
  .cred-header {
    text-align: center;
    margin-bottom: 52px;
  }
  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #534AB7;
    margin-bottom: 14px;
  }
  .eyebrow-line {
    display: inline-block;
    width: 28px;
    height: 1px;
    background: #F2D832;
    flex-shrink: 0;
  }
  .cred-h2 {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 44px;
    font-weight: 800;
    letter-spacing: -0.03em;
    color: #1a1744;
    line-height: 1.1;
    margin-bottom: 12px;
  }
  .cred-intro {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 16px;
    font-weight: 400;
    color: #7e7a9f;
    max-width: 440px;
    margin: 0 auto;
    line-height: 1.7;
  }

  /* Award card */
  .award-card {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    align-items: stretch;
    background: #ffffff;
    border-radius: 24px;
    overflow: hidden;
    box-shadow: 0 8px 48px rgba(38, 33, 92, 0.1);
    margin-bottom: 24px;
  }

  .award-img {
    width: 100%;
    height: 100%;
    min-height: 520px;
    object-fit: cover;
    display: block;
  }

  .award-content-col {
    padding: 52px 48px;
    display: flex;
    flex-direction: column;
  }

  .award-badge {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #F2D832;
    background: #1a1744;
    padding: 7px 14px;
    border-radius: 9999px;
    align-self: flex-start;
    margin-bottom: 24px;
  }

  .award-h3 {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 28px;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: #1a1744;
    line-height: 1.2;
    margin-bottom: 20px;
  }

  .award-body {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 15px;
    font-weight: 400;
    color: #5a5680;
    line-height: 1.8;
    margin-bottom: 14px;
  }

  /* Pull quote */
  .award-pullquote {
    display: flex;
    gap: 8px;
    align-items: flex-start;
    background: #f8f7ff;
    border-left: 3px solid #F2D832;
    border-radius: 0 12px 12px 0;
    padding: 16px 20px;
    margin: 8px 0 24px;
  }
  .pq-mark {
    font-family: Georgia, serif;
    font-size: 52px;
    line-height: 0.7;
    color: #F2D832;
    flex-shrink: 0;
    margin-top: 6px;
  }
  .pq-text {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 15px;
    font-weight: 500;
    font-style: italic;
    color: #4a4670;
    line-height: 1.65;
  }

  /* Award graphic */
  .award-graphic-wrap {
    margin-top: auto;
    display: flex;
    justify-content: center;
  }
  .award-graphic {
    width: 180px;
    height: auto;
    display: block;
  }

  /* Trusted by strip */
  .trusted-strip {
    background: #ffffff;
    border-radius: 20px;
    padding: 28px 40px;
    display: flex;
    align-items: center;
    gap: 28px;
    flex-wrap: wrap;
    box-shadow: 0 2px 16px rgba(38, 33, 92, 0.06);
  }
  .trusted-label {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #9c97c0;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .trusted-brand {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    flex-shrink: 0;
    opacity: 1;
    transition: opacity 0.2s;
  }
  .trusted-brand:hover { opacity: 0.75; }
  .trusted-logo {
    display: block;
    height: 44px;
    width: auto;
    object-fit: contain;
    border-radius: 8px;
  }
  .trusted-divider {
    width: 1px;
    height: 40px;
    background: #e8e5f8;
    flex-shrink: 0;
  }
  .trusted-also {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
    flex: 1;
  }
  .trusted-also-label {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #b8b4d8;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .trusted-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .trusted-chip {
    display: inline-flex;
    align-items: center;
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 12px;
    font-weight: 600;
    color: #534AB7;
    background: #EEEDFE;
    border: 1px solid #d4d0ff;
    padding: 6px 14px;
    border-radius: 9999px;
    white-space: nowrap;
  }

  /* ── Tablet ──────────────────────────────── */
  @media (max-width: 1024px) {
    .award-card { grid-template-columns: 1fr; }
    .award-content-col { padding: 40px; }
    .award-img { min-height: 320px; }
    .cred-h2 { font-size: 34px; }
    .trusted-strip { flex-wrap: wrap; gap: 16px; }
    .trusted-divider { display: none; }
    .trusted-also { flex-direction: column; align-items: flex-start; gap: 10px; }
  }

  /* ── Mobile ──────────────────────────────── */
  @media (max-width: 640px) {
    .credentials { padding: 52px 0; }
    .cred-h2 { font-size: 26px; }
    .award-content-col { padding: 28px 24px; }
    .award-h3 { font-size: 22px; }
    .trusted-strip { padding: 20px 24px; flex-direction: column; align-items: flex-start; gap: 14px; }
    .trusted-also { flex-direction: column; align-items: flex-start; gap: 8px; }
  }
</style>
