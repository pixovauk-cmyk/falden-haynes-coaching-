---
// ExitPopup.astro — exit-intent popup
// Split: left dark navy photo | right light #f8f9fb CTA
// Desktop: mouse exits top · Mobile: 30s timer
// 24h localStorage dismiss TTL
---

<div id="ep-backdrop" class="ep-backdrop" aria-hidden="true"></div>

<div
  id="ep-popup"
  class="ep-popup"
  role="dialog"
  aria-modal="true"
  aria-label="Free discovery call offer"
  aria-hidden="true"
  inert
>
  <button id="ep-close" class="ep-close" aria-label="Close">
    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
      <line x1="13" y1="3" x2="3" y2="13" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      <line x1="3"  y1="3" x2="13" y2="13" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
    </svg>
  </button>

  <!-- LEFT — dark navy + photo -->
  <div class="ep-left">
    <img
      src="/Images/feldon-haynes-thoughtful-portrait.webp"
      alt="Feldon Haynes, business coach and mentor"
      class="ep-photo"
      loading="lazy"
      width="400"
      height="560"
    />
    <!-- Quote badge sitting over photo -->
    <div class="ep-quote-badge">
      <p class="ep-quote-text">"I will tell you honestly whether I think I can help."</p>
      <span class="ep-quote-name">Feldon Haynes</span>
    </div>
  </div>

  <!-- RIGHT — light CTA -->
  <div class="ep-right">
    <div class="ep-right-blob" aria-hidden="true"></div>

    <span class="ep-chip">One last thing</span>

    <h2 class="ep-h2">Before<br />you go.</h2>

    <p class="ep-body">
      Your first call is free. 30 minutes. No pitch, no commitment.
      Just an honest conversation about where you are and what is possible.
    </p>

    <ul class="ep-checks">
      <li>
        <svg class="ep-check-icon" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <circle cx="10" cy="10" r="10" fill="#534AB7"/>
          <path d="M6 10.5l2.8 2.8 5-5.4" stroke="#fff" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Honest. Not just what you want to hear.
      </li>
      <li>
        <svg class="ep-check-icon" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <circle cx="10" cy="10" r="10" fill="#534AB7"/>
          <path d="M6 10.5l2.8 2.8 5-5.4" stroke="#fff" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Written action plan the same day
      </li>
      <li>
        <svg class="ep-check-icon" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <circle cx="10" cy="10" r="10" fill="#534AB7"/>
          <path d="M6 10.5l2.8 2.8 5-5.4" stroke="#fff" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        35+ businesses started. Real experience.
      </li>
    </ul>

    <a
      href="https://calendly.com/feldeluxe/discovery-call"
      id="ep-cta-link"
      class="ep-btn"
      target="_blank"
      rel="noopener noreferrer"
    >
      Book my free discovery call
    </a>

    <button id="ep-dismiss" class="ep-dismiss">
      No thanks, I'll work it out myself
    </button>
  </div>
</div>

<style>
  /* ── Backdrop ───────────────────────────────── */
  .ep-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(15, 12, 45, 0.65);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    z-index: 9000;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.35s ease;
  }
  .ep-backdrop.ep-open { opacity: 1; pointer-events: auto; }

  /* ── Popup shell ─────────────────────────────── */
  .ep-popup {
    position: fixed;
    inset: 0;
    margin: auto;
    width: min(860px, 92vw);
    height: fit-content;
    max-height: 90vh;
    z-index: 9001;
    display: grid;
    grid-template-columns: 340px 1fr;
    border-radius: 24px;
    overflow: hidden;
    box-shadow: 0 40px 100px rgba(15, 12, 45, 0.36), 0 8px 28px rgba(15, 12, 45, 0.14);
    opacity: 0;
    pointer-events: none;
    transform: translateY(20px) scale(0.97);
    transition: opacity 0.35s ease, transform 0.35s ease;
  }
  .ep-popup.ep-open {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0) scale(1);
  }

  /* ── Close button ────────────────────────────── */
  .ep-close {
    position: absolute;
    top: 14px;
    right: 14px;
    z-index: 20;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.15);
    border: 1px solid rgba(255, 255, 255, 0.2);
    color: #ffffff;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.2s;
    flex-shrink: 0;
  }
  .ep-close:hover { background: rgba(255,255,255,0.28); }

  /* ── LEFT — dark navy photo half ─────────────── */
  .ep-left {
    position: relative;
    background: linear-gradient(160deg, #1a1744 0%, #26215C 60%, #2d2a6e 100%);
    overflow: hidden;
  }
  .ep-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    display: block;
    mix-blend-mode: luminosity;
    opacity: 0.75;
  }
  /* Right-edge fade into the CTA side */
  .ep-left::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, transparent 55%, #26215C 100%);
    pointer-events: none;
  }

  /* Quote badge bottom-left of photo */
  .ep-quote-badge {
    position: absolute;
    bottom: 28px;
    left: 20px;
    right: 20px;
    z-index: 2;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 14px;
    padding: 14px 16px;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }
  .ep-quote-text {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 12px;
    font-style: italic;
    color: rgba(255, 255, 255, 0.85);
    line-height: 1.55;
    margin-bottom: 8px;
  }
  .ep-quote-name {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 11px;
    font-weight: 700;
    color: #F2D832;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  /* ── RIGHT — light CTA half ──────────────────── */
  .ep-right {
    background: #f8f9fb;
    padding: 48px 40px 40px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }
  .ep-right-blob {
    position: absolute;
    top: -80px;
    right: -80px;
    width: 260px;
    height: 260px;
    border-radius: 50%;
    background: radial-gradient(circle, #e3dfff 0%, rgba(227,223,255,0) 70%);
    pointer-events: none;
  }

  .ep-chip {
    display: inline-flex;
    width: fit-content;
    background: #e3dfff;
    color: #3b309e;
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 5px 13px;
    border-radius: 9999px;
    margin-bottom: 16px;
  }

  .ep-h2 {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 38px;
    font-weight: 800;
    letter-spacing: -0.03em;
    color: #1a1744;
    line-height: 1.1;
    margin-bottom: 14px;
  }

  .ep-body {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 13.5px;
    color: #5a5680;
    line-height: 1.75;
    margin-bottom: 20px;
  }

  .ep-checks {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 9px;
    margin-bottom: 26px;
  }
  .ep-checks li {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 13px;
    font-weight: 500;
    color: #3d3a5c;
  }
  .ep-check-icon { width: 20px; height: 20px; flex-shrink: 0; }

  .ep-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    background: #534AB7;
    color: #ffffff;
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 14px;
    font-weight: 700;
    padding: 15px 24px;
    border-radius: 9999px;
    text-decoration: none;
    min-height: 50px;
    transition: background 0.2s, transform 0.1s;
    box-shadow: 0 6px 22px rgba(83, 74, 183, 0.3);
    margin-bottom: 12px;
  }
  .ep-btn:hover { background: #3b309e; }
  .ep-btn:active { transform: scale(0.97); }

  .ep-dismiss {
    background: none;
    border: none;
    cursor: pointer;
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 12px;
    color: #b0abc8;
    text-align: center;
    padding: 4px;
    transition: color 0.2s;
  }
  .ep-dismiss:hover { color: #7e7a9f; }

  /* ── Tablet ──────────────────────────────────── */
  @media (max-width: 768px) {
    .ep-popup {
      grid-template-columns: 280px 1fr;
      width: min(780px, 92vw);
    }
    .ep-right { padding: 36px 28px 32px; }
    .ep-h2 { font-size: 30px; }
  }

  /* ── Mobile — bottom sheet ───────────────────── */
  @media (max-width: 580px) {
    .ep-popup {
      /* Override centered positioning — anchor to bottom */
      inset: auto;
      bottom: 0;
      left: 0;
      right: 0;
      margin: 0;
      width: 100%;
      max-height: 88vh;
      overflow-y: auto;
      -webkit-overflow-scrolling: touch;
      border-radius: 24px 24px 0 0;
      /* Single column — no photo panel */
      grid-template-columns: 1fr;
      /* Slide up animation instead of scale */
      transform: translateY(40px);
    }
    .ep-popup.ep-open {
      transform: translateY(0);
    }
    /* Hide photo panel — not needed on mobile */
    .ep-left { display: none; }
    .ep-right {
      padding: 32px 24px 36px;
      border-radius: 0;
    }
    .ep-right-blob { top: -40px; right: -40px; width: 180px; height: 180px; }
    .ep-h2 { font-size: 28px; }
    .ep-body { font-size: 13px; margin-bottom: 16px; }
    .ep-checks { gap: 8px; margin-bottom: 20px; }
    /* Close button: visible on light background */
    .ep-close {
      top: 12px;
      right: 12px;
      background: rgba(83, 74, 183, 0.1);
      border-color: rgba(83, 74, 183, 0.2);
      color: #534AB7;
    }
    .ep-close:hover { background: rgba(83, 74, 183, 0.18); }
  }

  @media (max-width: 380px) {
    .ep-right { padding: 28px 20px 32px; }
    .ep-h2 { font-size: 26px; }
  }
</style>

<script>
  const STORAGE_KEY = 'ep_dismissed';
  const TTL_MS = 24 * 60 * 60 * 1000;

  function isDismissed(): boolean {
    try {
      const raw = localStorage.getItem(STORAGE_KEY);
      if (!raw) return false;
      return Date.now() - parseInt(raw, 10) < TTL_MS;
    } catch { return false; }
  }

  function setDismissed() {
    try { localStorage.setItem(STORAGE_KEY, String(Date.now())); } catch {}
  }

  function openPopup() {
    if (isDismissed()) return;
    const popup    = document.getElementById('ep-popup')!;
    const backdrop = document.getElementById('ep-backdrop')!;
    popup.removeAttribute('inert');
    popup.classList.add('ep-open');
    backdrop.classList.add('ep-open');
    popup.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }

  function closePopup(markDismissed = true) {
    const popup    = document.getElementById('ep-popup')!;
    const backdrop = document.getElementById('ep-backdrop')!;
    popup.classList.remove('ep-open');
    backdrop.classList.remove('ep-open');
    popup.setAttribute('aria-hidden', 'true');
    popup.setAttribute('inert', '');
    document.body.style.overflow = '';
    if (markDismissed) setDismissed();
  }

  if (!isDismissed()) {
    let fired = false;

    function fire() {
      if (fired) return;
      fired = true;
      clearTimeout(fallback);
      openPopup();
    }

    // Desktop exit intent — mouse leaves through top edge
    document.addEventListener('mouseleave', (e) => {
      if ((e as MouseEvent).clientY <= 2) fire();
    });

    // Mobile / fallback — 30 seconds
    const fallback = setTimeout(fire, 30_000);
  }

  document.getElementById('ep-close')   ?.addEventListener('click', () => closePopup());
  document.getElementById('ep-dismiss') ?.addEventListener('click', () => closePopup());
  document.getElementById('ep-backdrop')?.addEventListener('click', () => closePopup());
  document.getElementById('ep-cta-link')?.addEventListener('click', () => closePopup());

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closePopup();
  });
</script>
