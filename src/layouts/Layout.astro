---
// Layout.astro — base layout for all pages
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import ExitPopup from '../components/ExitPopup.astro';
import CookieBanner from '../components/CookieBanner.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  ogImage?: string;
  ogType?: string;
  schema?: string;
  noindex?: boolean;
  preloadImage?: string;
  preloadImageMobile?: string;
  preloadImageMobileBreakpoint?: string;
}

const {
  title,
  description,
  canonicalUrl = Astro.url.href,
  ogImage = '/Images/feldon-haynes-thoughtful-portrait.webp',
  ogType = 'website',
  schema,
  noindex = false,
  preloadImage,
  preloadImageMobile,
  preloadImageMobileBreakpoint = '860px',
} = Astro.props;

const siteUrl = 'https://feldonhaynes.com'; // Confirm domain before launch
const fullOgImage = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`;
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- DNS prefetch for third-party resources -->
    <link rel="dns-prefetch" href="https://calendly.com" />
    <link rel="dns-prefetch" href="https://assets.calendly.com" />

    <!-- LCP image preload — pass preloadImage from page-level hero images -->
    {preloadImage && (
      <link rel="preload" as="image" href={preloadImage} fetchpriority="high" media={preloadImageMobile ? `(min-width: ${preloadImageMobileBreakpoint})` : undefined} />
    )}
    {preloadImageMobile && (
      <link rel="preload" as="image" href={preloadImageMobile} fetchpriority="high" media={`(max-width: ${preloadImageMobileBreakpoint})`} />
    )}

    <!-- Fonts — preconnect first, then async load (non-render-blocking) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,400;0,500;0,600;0,700;0,800;1,600;1,700&display=swap"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,400;0,500;0,600;0,700;0,800;1,600;1,700&display=swap"
      />
    </noscript>

    <!-- Primary meta -->
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Canonical -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type"        content={ogType} />
    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image"       content={fullOgImage} />
    <meta property="og:url"         content={canonicalUrl} />
    <meta property="og:site_name"   content="Feldon Haynes Coaching" />
    <meta property="og:locale"      content="en_GB" />

    <!-- Twitter card -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={fullOgImage} />

    <!-- Favicon -->
    <link rel="icon" type="image/png" sizes="32x32"  href="/Images/Logo/feldon-haynes-favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16"  href="/Images/Logo/feldon-haynes-favicon-16.png" />
    <link rel="apple-touch-icon" sizes="256x256"     href="/Images/Logo/feldon-haynes-favicon-256.png" />

    <!-- GA4 — placeholder until ID confirmed -->
    <!-- [GA4_ID] — add once Feldon provides G-XXXXXXXXXX -->

    <!-- GSC verification — placeholder -->
    <!-- [GSC_TAG] — add once Feldon provides verification tag -->

    <!-- Schema JSON-LD -->
    {schema && <script type="application/ld+json" set:html={schema} />}
  </head>
  <body>
    <Nav />
    <main id="main-content">
      <slot />
    </main>
    <Footer />

    <ExitPopup />
    <CookieBanner />

    <!-- WhatsApp floating button -->
    <a
      href="https://wa.me/447562614867"
      class="wa-float"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Chat with Feldon on WhatsApp"
    >
      <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
        <path d="M12 0C5.373 0 0 5.373 0 12c0 2.123.554 4.118 1.528 5.849L.057 23.25a.75.75 0 0 0 .952.902l5.65-1.81A11.945 11.945 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.75a9.737 9.737 0 0 1-4.953-1.35l-.355-.21-3.685 1.18 1.198-3.579-.23-.368A9.738 9.738 0 0 1 2.25 12C2.25 6.615 6.615 2.25 12 2.25S21.75 6.615 21.75 12 17.385 21.75 12 21.75z"/>
      </svg>
      <span class="wa-label">WhatsApp</span>
    </a>

    <style>
      .wa-float {
        position: fixed;
        bottom: calc(28px + var(--cookie-offset, 0px));
        right: 28px;
        z-index: 999;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        background: #25D366;
        color: #ffffff;
        padding: 13px 20px 13px 16px;
        border-radius: 9999px;
        text-decoration: none;
        box-shadow: 0 4px 20px rgba(37, 211, 102, 0.45);
        font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
        font-size: 14px;
        font-weight: 600;
        transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
        white-space: nowrap;
      }
      .wa-float:hover {
        background: #1ebe5d;
        transform: translateY(-2px);
        box-shadow: 0 8px 28px rgba(37, 211, 102, 0.5);
      }
      .wa-float:active { transform: scale(0.97); }

      @media (max-width: 640px) {
        .wa-float {
          bottom: calc(20px + var(--cookie-offset, 0px));
          right: 16px;
          padding: 13px 16px;
        }
        .wa-label { display: none; }
      }
    </style>

    <!-- Intersection Observer — fade-in on scroll -->
    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1 }
      );
      document.querySelectorAll('.fade-in').forEach((el) => observer.observe(el));
    </script>
  </body>
</html>
