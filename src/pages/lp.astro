---
// lp.astro — High-converting landing page
// Goal: Book free discovery call | Audience: Cold + warm traffic
// No nav, no footer — uses LpLayout (pure conversion)

import LpLayout from '../layouts/LpLayout.astro';

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Free Business Coaching Discovery Call",
  "provider": {
    "@type": "Person",
    "name": "Feldon Haynes",
    "url": "https://feldeluxe.com"
  },
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "GBP",
    "description": "Free 30-minute discovery call with business coach Feldon Haynes"
  }
});
---

<LpLayout
  title="Work With a Business Coach Who Has Actually Built Businesses | Feldon Haynes"
  description="Book a free 30-minute discovery call with Feldon Haynes. 35+ businesses started. 40+ founders coached. Honest advice. Real plans. No pitch."
  canonicalUrl="https://feldeluxe.com/lp"
  noindex={true}
  schema={schema}
>

<!-- ── TOP BAR ─────────────────────────────────── -->
<header class="lp-bar">
  <div class="lp-container lp-bar-inner">
    <a href="/" aria-label="Feldon Haynes Coaching — home">
      <img src="/Images/feldon-haynes-logo-light.webp" alt="Feldon Haynes Coaching" width="82" height="48" loading="eager" class="lp-logo-img" />
    </a>
    <a href="https://calendly.com/feldeluxe/discovery-call" class="lp-bar-cta" target="_blank" rel="noopener noreferrer">
      Book a free call
    </a>
  </div>
</header>

<!-- ── HERO — light theme matching home page ────── -->
<section class="lp-hero">
  <div class="lp-container">
    <div class="hero-grid">

      <!-- Left: copy -->
      <div class="hero-copy fade-in">
        <span class="hero-chip">Free 30-minute discovery call</span>

        <h1 class="hero-h1">
          A business coach who has<br />
          <em>actually</em> built businesses.
        </h1>

        <p class="hero-sub">
          35 businesses started. 40+ founders coached. Based in the West Midlands,
          working with founders across the UK.
        </p>

        <ul class="hero-checks">
          <li>
            <svg class="check-icon" viewBox="0 0 22 22" fill="none" aria-hidden="true"><circle cx="11" cy="11" r="11" fill="#534AB7"/><path d="M7 11.5l3 3 5-6" stroke="#fff" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Honest advice. Not just what you want to hear.
          </li>
          <li>
            <svg class="check-icon" viewBox="0 0 22 22" fill="none" aria-hidden="true"><circle cx="11" cy="11" r="11" fill="#534AB7"/><path d="M7 11.5l3 3 5-6" stroke="#fff" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Written action plan after every session, same day
          </li>
          <li>
            <svg class="check-icon" viewBox="0 0 22 22" fill="none" aria-hidden="true"><circle cx="11" cy="11" r="11" fill="#534AB7"/><path d="M7 11.5l3 3 5-6" stroke="#fff" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Discovery call is free. No commitment, no pitch.
          </li>
          <li>
            <svg class="check-icon" viewBox="0 0 22 22" fill="none" aria-hidden="true"><circle cx="11" cy="11" r="11" fill="#534AB7"/><path d="M7 11.5l3 3 5-6" stroke="#fff" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Structured bundles from £90. No vague retainers.
          </li>
        </ul>

        <a href="https://calendly.com/feldeluxe/discovery-call" class="hero-cta-btn" target="_blank" rel="noopener noreferrer">
          Book your free 30-minute call
        </a>
        <p class="hero-cta-note">Free · No obligation · Wednesdays and Thursdays</p>

        <div class="hero-proof">
          <div class="hero-avatars" aria-hidden="true">
            <img src="https://images.pexels.com/photos/1043474/pexels-photo-1043474.jpeg?auto=compress&cs=tinysrgb&w=80&h=80&fit=crop&crop=face" alt="" class="hero-avatar" width="80" height="80" loading="lazy" />
            <img src="https://images.pexels.com/photos/220453/pexels-photo-220453.jpeg?auto=compress&cs=tinysrgb&w=80&h=80&fit=crop&crop=face" alt="" class="hero-avatar" width="80" height="80" loading="lazy" />
            <img src="https://images.pexels.com/photos/774909/pexels-photo-774909.jpeg?auto=compress&cs=tinysrgb&w=80&h=80&fit=crop&crop=face" alt="" class="hero-avatar" width="80" height="80" loading="lazy" />
            <img src="https://images.pexels.com/photos/1681010/pexels-photo-1681010.jpeg?auto=compress&cs=tinysrgb&w=80&h=80&fit=crop&crop=face" alt="" class="hero-avatar" width="80" height="80" loading="lazy" />
          </div>
          <p class="hero-proof-text"><strong>40+ founders</strong> already working with Feldon</p>
        </div>
      </div>

      <!-- Right: Feldon photo + floating badges -->
      <div class="hero-visual" aria-hidden="true">
        <div class="hero-blob"></div>
        <div class="hero-img-wrap">
          <img
            src="/Images/feldon-haynes-professional-headshot.webp"
            alt="Feldon Haynes, business coach"
            width="480"
            height="580"
            loading="eager"
            class="hero-img"
          />
          <div class="hero-badge hero-badge--tl">
            <span class="badge-num">35+</span>
            <span class="badge-label">Businesses started</span>
          </div>
          <div class="hero-badge hero-badge--br">
            <span class="badge-num">40+</span>
            <span class="badge-label">Founders coached</span>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- ── PAIN POINTS ───────────────────────────────── -->
<section class="lp-pain">
  <div class="lp-container">
    <div class="section-header fade-in">
      <p class="eyebrow"><span class="eyebrow-line" aria-hidden="true"></span>You are in the right place if…</p>
    </div>
    <div class="pain-scroll-wrap" id="pain-scroll">
      <div class="pain-grid">
        <div class="pain-card fade-in">
          <div class="pain-icon-wrap">
            <svg width="26" height="26" viewBox="0 0 26 26" fill="none" aria-hidden="true"><path d="M13 3v10l6 3" stroke="#534AB7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><circle cx="13" cy="13" r="11" stroke="#534AB7" stroke-width="1.5"/></svg>
          </div>
          <h3 class="pain-title">You have the idea. Not the plan.</h3>
          <p class="pain-body">You know what you want to build. You just cannot figure out how to turn it into something real. Every week you delay costs you.</p>
        </div>
        <div class="pain-card pain-card--dark fade-in">
          <div class="pain-icon-wrap pain-icon-wrap--light">
            <svg width="26" height="26" viewBox="0 0 26 26" fill="none" aria-hidden="true"><path d="M13 5v8l5 5" stroke="#F2D832" stroke-width="2" stroke-linecap="round"/><circle cx="13" cy="13" r="11" stroke="#F2D832" stroke-width="1.5"/></svg>
          </div>
          <h3 class="pain-title pain-title--light">You are running a business but feel stuck.</h3>
          <p class="pain-body pain-body--light">The business is moving but it feels reactive, unfocused, or headed somewhere you did not intend. You need someone outside it to help you see clearly.</p>
        </div>
        <div class="pain-card fade-in">
          <div class="pain-icon-wrap">
            <svg width="26" height="26" viewBox="0 0 26 26" fill="none" aria-hidden="true"><path d="M8 13h10M13 8l5 5-5 5" stroke="#534AB7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><circle cx="13" cy="13" r="11" stroke="#534AB7" stroke-width="1.5"/></svg>
          </div>
          <h3 class="pain-title">You know what to do. You just need someone to push you.</h3>
          <p class="pain-body">You have enough knowledge. What you need is accountability, structure, and someone who will tell you the truth rather than agree with everything.</p>
        </div>
      </div>
    </div>
    <div class="lp-carousel-nav pain-carousel-nav">
      <button class="lp-carousel-btn" id="pain-prev" aria-label="Previous">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true"><path d="M11 4L6 9l5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
      <button class="lp-carousel-btn" id="pain-next" aria-label="Next">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true"><path d="M7 4l5 5-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
    </div>
  </div>
</section>

<!-- ── TESTIMONIALS 1 ────────────────────────────── -->
<section class="lp-t1">
  <div class="lp-container">
    <div class="section-header fade-in">
      <p class="eyebrow"><span class="eyebrow-line" aria-hidden="true"></span>What founders say</p>
      <h2 class="section-h2">Real feedback. Real names.</h2>
    </div>
    <div class="t1-scroll-wrap" id="t1-scroll">
      <div class="t1-grid">
        <div class="t1-card fade-in">
          <div class="t1-stars">★★★★★</div>
          <p class="t1-quote">"I attended a marketing webinar led by Feldon Haynes. He was very friendly and supportive throughout — ensuring everyone understood everything. He explained it clearly and even answered my questions in depth. I learnt a lot."</p>
          <div class="t1-author">
            <img src="https://images.pexels.com/photos/1065084/pexels-photo-1065084.jpeg?auto=compress&cs=tinysrgb&w=80&h=80&fit=crop&crop=face" alt="" class="t1-avatar" aria-hidden="true" width="80" height="80" loading="lazy" />
            <div><p class="t1-name">Workshop attendee</p><p class="t1-source">Trustpilot review</p></div>
          </div>
        </div>
        <div class="t1-card t1-card--featured fade-in">
          <div class="t1-stars">★★★★★</div>
          <p class="t1-quote">"Where do I start with Feldon? He is not only a sharp individual but someone who truly cares about his clients. Kind, humble, and always willing to lend support — a rare combination. Every conversation has been insightful."</p>
          <div class="t1-author">
            <img src="https://images.pexels.com/photos/2379004/pexels-photo-2379004.jpeg?auto=compress&cs=tinysrgb&w=80&h=80&fit=crop&crop=face" alt="" class="t1-avatar" aria-hidden="true" width="80" height="80" loading="lazy" />
            <div><p class="t1-name">Business owner</p><p class="t1-source">LinkedIn recommendation</p></div>
          </div>
        </div>
        <div class="t1-card fade-in">
          <div class="t1-stars">★★★★★</div>
          <p class="t1-quote">"I reached out to Feldon because he was recommended to me. I was looking at a new venture and was lost. He was extremely helpful — specific places to look, people to contact, grants to consider. Not just advice. Actions."</p>
          <div class="t1-author">
            <img src="https://images.pexels.com/photos/3756679/pexels-photo-3756679.jpeg?auto=compress&cs=tinysrgb&w=80&h=80&fit=crop&crop=face" alt="" class="t1-avatar" aria-hidden="true" width="80" height="80" loading="lazy" />
            <div><p class="t1-name">New venture founder</p><p class="t1-source">Trustpilot review</p></div>
          </div>
        </div>
      </div>
    </div>
    <div class="lp-carousel-nav t1-carousel-nav">
      <button class="lp-carousel-btn" id="t1-prev" aria-label="Previous">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true"><path d="M11 4L6 9l5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
      <button class="lp-carousel-btn" id="t1-next" aria-label="Next">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true"><path d="M7 4l5 5-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
    </div>
  </div>
</section>

<!-- ── HOW IT WORKS ──────────────────────────────── -->
<section class="lp-how">
  <div class="lp-container">
    <div class="section-header fade-in">
      <p class="eyebrow eyebrow--light"><span class="eyebrow-line" aria-hidden="true"></span>The process</p>
      <h2 class="section-h2 section-h2--light">Simple. Structured. No surprises.</h2>
    </div>
    <div class="how-scroll-wrap" id="how-scroll">
      <div class="how-grid">
        <div class="how-step fade-in">
          <div class="how-num">01</div>
          <div class="how-img-wrap">
            <img src="https://images.pexels.com/photos/4226140/pexels-photo-4226140.jpeg?auto=compress&cs=tinysrgb&w=600&h=380&fit=crop" alt="Booking a call online" width="600" height="380" loading="lazy" class="how-img" />
          </div>
          <h3 class="how-title">Book your free call</h3>
          <p class="how-body">Pick a Wednesday or Thursday slot on Calendly. 30 minutes. Free. I will listen to where you are and tell you honestly whether I think I can help.</p>
        </div>
        <div class="how-step fade-in">
          <div class="how-num">02</div>
          <div class="how-img-wrap">
            <img src="/Images/feldon-haynes-whiteboard-strategy-session.webp" alt="Feldon running a strategy session" width="600" height="380" loading="lazy" class="how-img" />
          </div>
          <h3 class="how-title">We get to work</h3>
          <p class="how-body">Sessions are focused and practical. No theory, no generic advice. I come prepared. You bring the problem. We build the solution together.</p>
        </div>
        <div class="how-step fade-in">
          <div class="how-num">03</div>
          <div class="how-img-wrap">
            <img src="https://images.pexels.com/photos/3760067/pexels-photo-3760067.jpeg?auto=compress&cs=tinysrgb&w=600&h=380&fit=crop" alt="Reviewing action plan after session" width="600" height="380" loading="lazy" class="how-img" />
          </div>
          <h3 class="how-title">You leave with a plan</h3>
          <p class="how-body">Every session ends with a written action plan in your inbox the same day. Not a summary. A real plan you can act on the next morning.</p>
        </div>
      </div>
    </div>
    <div class="lp-carousel-nav how-carousel-nav">
      <button class="lp-carousel-btn lp-carousel-btn--light" id="how-prev" aria-label="Previous">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true"><path d="M11 4L6 9l5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
      <button class="lp-carousel-btn lp-carousel-btn--light" id="how-next" aria-label="Next">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true"><path d="M7 4l5 5-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
    </div>
    <div class="how-cta fade-in">
      <a href="https://calendly.com/feldeluxe/discovery-call" class="lp-btn-gold" target="_blank" rel="noopener noreferrer">Book your free discovery call</a>
      <p class="how-note">Free · 30 minutes · No commitment required</p>
    </div>
  </div>
</section>

<!-- ── ABOUT FELDON ──────────────────────────────── -->
<section class="lp-about">
  <div class="lp-container">
    <div class="about-grid">
      <div class="about-img-col fade-in">
        <img src="/Images/feldon-haynes-award-photo.webp" alt="Feldon Haynes receiving the EPIC Spirit Award" width="480" height="480" loading="lazy" class="about-award-img" />
      </div>
      <div class="about-copy fade-in">
        <p class="eyebrow"><span class="eyebrow-line" aria-hidden="true"></span>About Feldon</p>
        <h2 class="about-h2">I did not read about this.<br />I lived it.</h2>
        <p class="about-body">I started my first business before most people my age were thinking about careers. Since then I have built 35 businesses. Not all of them worked, and that is exactly the point.</p>
        <p class="about-body">The lessons that matter most do not come from the businesses that went smoothly. They come from figuring out what went wrong and what you would do differently. That experience is what I bring to every session.</p>
        <p class="about-body">I have delivered workshops at the University of Warwick Science Park, worked with the Black Country Chamber of Commerce, and spent years in rooms with founders who are building something real.</p>
        <div class="about-stats">
          <div class="about-stat"><span class="stat-num">35+</span><span class="stat-label">Businesses started</span></div>
          <div class="about-stat"><span class="stat-num">40+</span><span class="stat-label">Founders coached</span></div>
          <div class="about-stat"><span class="stat-num">3</span><span class="stat-label">Industry awards</span></div>
        </div>
        <a href="https://calendly.com/feldeluxe/discovery-call" class="lp-btn-primary" target="_blank" rel="noopener noreferrer">Book your free call</a>
      </div>
    </div>
  </div>
</section>

<!-- ── BUNDLES ───────────────────────────────────── -->
<section class="lp-bundles">
  <div class="lp-container">
    <div class="section-header fade-in" style="text-align:center">
      <span class="b-chip">Investment bundles</span>
      <h2 class="b-h2">Choose your starting point</h2>
      <p class="b-intro">Launch pricing. All sessions online, Wednesdays and Thursdays, 8am to 6pm.</p>
    </div>
    <div class="b-scroll-wrap" id="b-scroll">
      <div class="b-grid fade-in">

        <article class="b-card">
          <div class="b-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg></div>
          <h3 class="b-name">The Project Bundle</h3>
          <p class="b-meta">3 sessions &middot; Specific project</p>
          <div class="b-price-row">
            <span class="b-price">&pound;90</span>
            <span class="b-was">&pound;150</span>
            <span class="b-save">Save £60</span>
          </div>
          <p class="b-desc">Three focused sessions to scope, map, and launch a specific project.</p>
          <a href="https://calendly.com/feldeluxe/packages/da7fbbe4-840c-4ea8-8147-2128f99cfd6b" class="b-btn b-btn--ghost" target="_blank" rel="noopener noreferrer">Select bundle</a>
        </article>

        <article class="b-card">
          <div class="b-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg></div>
          <h3 class="b-name">The Action Sprint Bundle</h3>
          <p class="b-meta">3 sessions &middot; Stuck founders</p>
          <div class="b-price-row">
            <span class="b-price">&pound;90</span>
            <span class="b-was">&pound;150</span>
            <span class="b-save">Save £60</span>
          </div>
          <p class="b-desc">Find the block, make the decision, and build a 30-day plan to move fast.</p>
          <a href="https://calendly.com/feldeluxe/packages/549dd535-e12c-4506-822a-9a839af25318" class="b-btn b-btn--ghost" target="_blank" rel="noopener noreferrer">Select bundle</a>
        </article>

        <article class="b-card b-card--popular">
          <div class="b-badge">Most Popular</div>
          <div class="b-icon b-icon--filled"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 3v4a1 1 0 0 0 1 1h4"/><path d="M17 21H7a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h7l5 5v11a2 2 0 0 1-2 2z"/><line x1="9" y1="13" x2="15" y2="13"/><line x1="9" y1="17" x2="15" y2="17"/></svg></div>
          <h3 class="b-name">The Business Plan Bundle</h3>
          <p class="b-meta">6 sessions &middot; Aspiring founders</p>
          <div class="b-price-row">
            <span class="b-price">&pound;160</span>
            <span class="b-was">&pound;300</span>
            <span class="b-save">Save £140</span>
          </div>
          <p class="b-desc">From idea to a complete, executable plan: validated, structured, and ready to launch.</p>
          <a href="https://calendly.com/feldeluxe/packages/8af8f4b4-b4fc-4b38-a4d7-4c8863f57ce5" class="b-btn b-btn--filled" target="_blank" rel="noopener noreferrer">Select bundle</a>
        </article>

        <article class="b-card">
          <div class="b-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"/></svg></div>
          <h3 class="b-name">The Direction Bundle</h3>
          <p class="b-meta">6 sessions &middot; Lost direction</p>
          <div class="b-price-row">
            <span class="b-price">&pound;160</span>
            <span class="b-was">&pound;300</span>
            <span class="b-save">Save £140</span>
          </div>
          <p class="b-desc">Business audit, vision work, and a 6-month strategic roadmap for existing businesses.</p>
          <a href="https://calendly.com/feldeluxe/packages/bcd3e931-3e20-4faa-9d96-2a82cc4e121a" class="b-btn b-btn--ghost" target="_blank" rel="noopener noreferrer">Select bundle</a>
        </article>

      </div>
    </div>

    <!-- Mobile carousel nav -->
    <div class="b-carousel-nav" aria-label="Scroll bundles">
      <button class="b-carousel-btn" id="b-prev" aria-label="Previous">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true"><path d="M11 4L6 9l5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
      <button class="b-carousel-btn" id="b-next" aria-label="Next">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true"><path d="M7 4l5 5-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
    </div>

    <p class="b-note fade-in">Not sure which fits? <a href="https://calendly.com/feldeluxe/discovery-call" target="_blank" rel="noopener noreferrer">Start with a free 30-minute discovery call &rarr;</a></p>
  </div>
</section>

<!-- ── MORE FROM FOUNDERS — Google Review cards ───── -->
<section class="lp-google">
  <div class="lp-container">
