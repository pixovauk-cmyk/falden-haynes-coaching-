<script>
  function initCarousel(wrapId: string, prevId: string, nextId: string, cardSel: string, gap = 14) {
    const wrap = document.getElementById(wrapId);
    const prev = document.getElementById(prevId);
    const next = document.getElementById(nextId);
    if (!wrap || !prev || !next) return;
    const step = () => { const c = wrap.querySelector(cardSel); return c ? (c as HTMLElement).offsetWidth + gap : 300; };
    prev.addEventListener('click', () => wrap.scrollBy({ left: -step(), behavior: 'smooth' }));
    next.addEventListener('click', () => wrap.scrollBy({ left: step(), behavior: 'smooth' }));
  }

  initCarousel('b-scroll',    'b-prev',    'b-next',    '.b-card',    14);
  initCarousel('pain-scroll', 'pain-prev', 'pain-next', '.pain-card', 14);
  initCarousel('t1-scroll',   't1-prev',   't1-next',   '.t1-card',   14);
  initCarousel('how-scroll',  'how-prev',  'how-next',  '.how-step',  20);
  initCarousel('gr-scroll',   'gr-prev',   'gr-next',   '.gr-card',   14);
</script>
