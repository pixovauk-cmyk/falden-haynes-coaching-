---
// privacy.astro — Privacy Policy
// No primary SEO keyword — noindex
// BEFORE LAUNCH: Review content against existing feldonhaynes.com/privacy and update if different

import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Privacy Policy | Feldon Haynes Coaching"
  description="Privacy Policy for Feldon Haynes Coaching (Feldon Haynes Coaching). How we collect, use, and protect your personal data."
  canonicalUrl="https://feldonhaynes.com/privacy"
  noindex={true}
>

  <section class="legal-hero">
    <div class="container">
      <p class="legal-breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true"> / </span>
        <span>Privacy Policy</span>
      </p>
      <h1 class="legal-h1">Privacy Policy</h1>
      <p class="legal-meta">Last updated: 27 June 2025 &middot; Feldon Haynes Coaching</p>
    </div>
  </section>

  <section class="legal-body">
    <div class="container legal-content">

      <p class="legal-intro">
        This Privacy Policy explains how Feldon Haynes Coaching (&ldquo;we&rdquo;, &ldquo;us&rdquo;, &ldquo;our&rdquo;) collects, uses, and protects the personal information you provide when you use this website or engage with our services. We are committed to handling your data responsibly and in accordance with the UK General Data Protection Regulation (UK GDPR) and the Data Protection Act 2018.
      </p>

      <h2>1. Who we are</h2>
      <p>The data controller responsible for your personal data is:</p>
      <address>
        <strong>Feldon Haynes Coaching</strong><br>
        32 Vicarage Road, Halesowen, West Midlands, B62 8HU, England<br>
        Companies House number: 16546926<br>
        Email: <a href="mailto:Feldonhaynes@gmail.com">Feldonhaynes@gmail.com</a><br>
        Phone: <a href="tel:+447562614867">07562 614867</a>
      </address>

      <h2>2. Information we collect</h2>
      <p>We may collect the following personal information:</p>
      <ul>
        <li><strong>Contact information</strong> — your name and email address when you submit our contact form or book a call via Calendly.</li>
        <li><strong>Message content</strong> — the message you write in our contact form.</li>
        <li><strong>Booking details</strong> — appointment dates, times, and any information you provide when booking a coaching session.</li>
        <li><strong>Usage data</strong> — information about how you use our website, collected via Google Analytics (if enabled). This may include your IP address, browser type, pages visited, and time spent on the site. See Section 8 for cookie details.</li>
      </ul>
      <p>We do not collect sensitive personal data (such as health information, financial data, or information about protected characteristics) unless you voluntarily share it during a coaching engagement.</p>

      <h2>3. How we use your information</h2>
      <p>We use your personal information to:</p>
      <ul>
        <li>Respond to enquiries submitted via the contact form or email.</li>
        <li>Manage and deliver coaching sessions you have booked.</li>
        <li>Send written action summaries and follow-up communications related to your coaching sessions.</li>
        <li>Improve our website and services based on usage analytics.</li>
        <li>Meet our legal and contractual obligations.</li>
      </ul>
      <p>We do not use your personal data for automated decision-making or profiling.</p>

      <h2>4. Legal basis for processing</h2>
      <p>We process your personal data on the following legal bases under UK GDPR:</p>
      <ul>
        <li><strong>Contract performance</strong> — when processing is necessary to deliver the coaching services you have engaged us for.</li>
        <li><strong>Legitimate interests</strong> — to respond to enquiries, manage bookings, and improve our services.</li>
        <li><strong>Legal obligation</strong> — where processing is required to comply with applicable law.</li>
        <li><strong>Consent</strong> — where we have asked for your consent (for example, for marketing communications, if applicable). You may withdraw consent at any time.</li>
      </ul>

      <h2>5. How we share your information</h2>
      <p>We do not sell, rent, or trade your personal data. We may share information with the following third-party service providers, solely for the purposes described above:</p>
      <ul>
        <li><strong>Calendly</strong> — for booking and appointment management. Subject to Calendly&rsquo;s own privacy policy.</li>
        <li><strong>Notion (via Zapier)</strong> — contact form submissions are stored in a Notion database. Both Zapier and Notion are subject to their own privacy policies.</li>
        <li><strong>Google Analytics</strong> — for anonymised website usage analytics. Subject to Google&rsquo;s privacy policy.</li>
        <li><strong>Stripe</strong> — for payment processing. We do not store payment card details. Subject to Stripe&rsquo;s privacy policy.</li>
      </ul>
      <p>All third-party processors are contractually required to handle your data securely and only for the purposes we specify.</p>

      <h2>6. How long we keep your data</h2>
      <p>We retain personal data only for as long as necessary:</p>
      <ul>
        <li>Contact form enquiries — up to 12 months from the date of submission, unless an ongoing coaching relationship requires longer retention.</li>
        <li>Coaching records (session notes, action summaries) — for the duration of the coaching engagement and up to 3 years thereafter, for contractual and legal purposes.</li>
        <li>Financial and payment records — 6 years, as required by UK tax law.</li>
      </ul>
      <p>When data is no longer required, it is securely deleted or anonymised.</p>

      <h2>7. Your rights</h2>
      <p>Under UK GDPR, you have the following rights in relation to your personal data:</p>
      <ul>
        <li><strong>Right of access</strong> — to request a copy of the personal data we hold about you.</li>
        <li><strong>Right to rectification</strong> — to ask us to correct inaccurate or incomplete data.</li>
        <li><strong>Right to erasure</strong> — to request deletion of your data, subject to legal obligations.</li>
        <li><strong>Right to restrict processing</strong> — to limit how we use your data in certain circumstances.</li>
        <li><strong>Right to data portability</strong> — to receive your data in a structured, machine-readable format.</li>
        <li><strong>Right to object</strong> — to object to processing based on legitimate interests.</li>
        <li><strong>Right to withdraw consent</strong> — where processing is based on consent, to withdraw it at any time.</li>
      </ul>
      <p>To exercise any of these rights, contact us at <a href="mailto:Feldonhaynes@gmail.com">Feldonhaynes@gmail.com</a>. We will respond within one calendar month.</p>
      <p>If you are unhappy with how we handle your data, you have the right to lodge a complaint with the <a href="https://ico.org.uk" target="_blank" rel="noopener noreferrer">Information Commissioner&rsquo;s Office (ICO)</a>.</p>

      <h2>8. Cookies</h2>
      <p>Our website may use cookies and similar tracking technologies. Cookies are small text files stored on your device that help us understand how the site is used.</p>
      <p>We may use:</p>
      <ul>
        <li><strong>Essential cookies</strong> — required for the site to function. No consent required.</li>
        <li><strong>Analytics cookies</strong> — via Google Analytics, to understand how visitors use the site. These are only set with your consent.</li>
      </ul>
      <p>You can manage or disable cookies through your browser settings at any time. Disabling analytics cookies will not affect your ability to use the site.</p>

      <h2>9. External links</h2>
      <p>Our website may contain links to third-party websites (such as Calendly, LinkedIn, or Trustpilot). We are not responsible for the privacy practices of those sites. We recommend reading their privacy policies before sharing any personal data with them.</p>

      <h2>10. Changes to this policy</h2>
      <p>We may update this Privacy Policy from time to time. The most recent version will always be available at <a href="/privacy">feldonhaynes.com/privacy</a>. The &ldquo;Last updated&rdquo; date at the top of this page will reflect any changes.</p>

      <h2>11. Contact us</h2>
      <p>For any questions about this Privacy Policy or how we handle your data, please contact:</p>
      <address>
        <strong>Feldon Haynes — Feldon Haynes Coaching</strong><br>
        Email: <a href="mailto:Feldonhaynes@gmail.com">Feldonhaynes@gmail.com</a><br>
        Phone: <a href="tel:+447562614867">07562 614867</a>
      </address>

    </div>
  </section>

</Layout>

<style>
  /* ── Hero ──────────────────────────────── */
  .legal-hero {
    background: #26215C;
    padding: 56px 0 48px;
  }

  .legal-breadcrumb {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 12px;
    color: rgba(255, 255, 255, 0.4);
    margin-bottom: 16px;
  }
  .legal-breadcrumb a {
    color: rgba(255, 255, 255, 0.4);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .legal-breadcrumb a:hover { color: rgba(255, 255, 255, 0.8); }

  .legal-h1 {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 40px;
    font-weight: 700;
    color: #ffffff;
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin-bottom: 10px;
  }

  .legal-meta {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 13px;
    color: rgba(255, 255, 255, 0.45);
  }

  /* ── Body ──────────────────────────────── */
  .legal-body {
    background: #FAF9F6;
    padding: 64px 0 80px;
  }

  .legal-content {
    max-width: 760px;
  }

  .legal-intro {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 16px;
    font-weight: 400;
    color: #26215C;
    line-height: 1.75;
    margin-bottom: 40px;
    padding-bottom: 40px;
    border-bottom: 1px solid #e4e2f5;
  }

  .legal-content h2 {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 16px;
    font-weight: 600;
    color: #26215C;
    margin-top: 40px;
    margin-bottom: 12px;
  }

  .legal-content p {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 15px;
    font-weight: 400;
    color: #444;
    line-height: 1.8;
    margin-bottom: 14px;
  }

  .legal-content ul {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 15px;
    font-weight: 400;
    color: #444;
    line-height: 1.75;
    margin: 0 0 14px 20px;
    padding: 0;
  }

  .legal-content ul li {
    margin-bottom: 8px;
  }

  .legal-content address {
    font-style: normal;
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 15px;
    color: #444;
    line-height: 1.8;
    background: #EEEDFE;
    border-left: 3px solid #534AB7;
    border-radius: 0 8px 8px 0;
    padding: 16px 20px;
    margin: 16px 0 14px;
  }

  .legal-content a {
    color: #534AB7;
    text-decoration: underline;
    text-decoration-color: rgba(83, 74, 183, 0.3);
    transition: text-decoration-color 0.2s ease;
  }
  .legal-content a:hover {
    text-decoration-color: #534AB7;
  }

  /* ── Mobile ────────────────────────────── */
  @media (max-width: 768px) {
    .legal-h1 { font-size: 28px; }
    .legal-hero { padding: 40px 0 32px; }
    .legal-body { padding: 40px 0 56px; }
  }
</style>
