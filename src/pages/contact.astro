---
// contact.astro — Contact page
import Layout from '../layouts/Layout.astro';
import QuizWidget from '../components/QuizWidget.astro';
import { reader } from '../lib/reader';

const cp   = await reader.singletons.contact_page.read();
const site = await reader.singletons.site_settings.read();

const heroHeading     = cp?.hero_heading      ?? 'Get in touch';
const heroSub         = cp?.hero_sub          ?? "Not sure where to start? Take the quick quiz below and I'll point you in the right direction.";
const quizHeading     = cp?.quiz_heading      ?? 'Not sure where to start?';
const quizBody        = cp?.quiz_body         ?? "Eight quick questions. I'll tell you which package fits where you are right now, or whether a free call makes more sense first.";
const optionsHeading  = cp?.options_heading   ?? "I'm easy to reach.";
const emailCardBody   = cp?.email_card_body   ?? "Send me a message and I'll reply within 48 hours.";
const waCardBody      = cp?.whatsapp_card_body ?? "Drop me a message and I'll get back to you.";
const callCardBody    = cp?.call_card_body    ?? '30 minutes, no pitch, no pressure. Just a conversation.';

const email    = site?.email          ?? 'Feldonhaynes@gmail.com';
const phone    = site?.phone          ?? '07562 614867';
const waUrl    = site?.whatsapp_url   ?? 'https://wa.me/447562614867';
const calendly = site?.calendly_discovery ?? 'https://calendly.com/feldon-haynes/discovery-call';

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://feldonhaynes.com/" },
        { "@type": "ListItem", "position": 2, "name": "Contact", "item": "https://feldonhaynes.com/contact" }
      ]
    },
    {
      "@type": "ContactPage",
      "name": "Contact Feldon Haynes Coaching",
      "url": "https://feldonhaynes.com/contact",
      "description": "Get in touch with Feldon Haynes. Book a free discovery call or reach out by email or WhatsApp.",
      "mainEntity": {
        "@type": "Person",
        "@id": "https://feldonhaynes.com/about#feldon-haynes",
        "name": "Feldon Haynes",
        "telephone": "+447562614867",
        "email": "Feldonhaynes@gmail.com"
      }
    }
  ]
});
---

<Layout
  title="Contact | Feldon Haynes Coaching"
  description="Get in touch with Feldon Haynes. Book a free 30-minute discovery call, email, or message on WhatsApp."
  canonicalUrl="https://feldonhaynes.com/contact"
  ogImage="/Images/feldon-haynes-professional-headshot.webp"
  preloadImage="/Images/feldon-haynes-whiteboard-strategy-session.webp"
  schema={schema}
>

  <!-- ── 1. Hero ────────────────────────────── -->
  <section class="contact-hero">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true">›</span>
        <span aria-current="page">Contact</span>
      </nav>
      <h1 class="hero-h1">{heroHeading}</h1>
      <p class="hero-sub">{heroSub}</p>
    </div>
  </section>

  <!-- ── 2. Quiz ────────────────────────────── -->
  <section class="quiz-section" aria-label="Find the right coaching package">
    <div class="container">
      <div class="quiz-wrap">

        <div class="quiz-intro fade-in">
          <p class="section-eyebrow section-eyebrow--purple">
            <span class="eyebrow-line eyebrow-line--dark" aria-hidden="true"></span>
            Find your fit
          </p>
          <h2 class="quiz-h2">{quizHeading}</h2>
          <p class="quiz-body">{quizBody}</p>
          <div class="quiz-trust">
            <div class="trust-item">
              <span class="trust-num">1 min</span>
              <span class="trust-label">to complete</span>
            </div>
            <div class="trust-divider" aria-hidden="true"></div>
            <div class="trust-item">
              <span class="trust-num">100%</span>
              <span class="trust-label">free, no commitment</span>
            </div>
          </div>
        </div>

        <div class="quiz-widget-wrap fade-in">
          <QuizWidget />
        </div>

      </div>
    </div>
  </section>

  <!-- ── 3. Contact options ─────────────────── -->
  <section class="contact-options" aria-label="Ways to get in touch">
    <div class="container">

      <div class="options-header fade-in">
        <p class="section-eyebrow">
          <span class="eyebrow-line eyebrow-line--dark" aria-hidden="true"></span>
          Prefer to reach out directly?
        </p>
        <h2 class="options-h2">{optionsHeading}</h2>
      </div>

      <div class="options-grid fade-in">

        <!-- Email -->
        <div class="option-card">
          <div class="option-icon">
            <img src="/Images/emailicon.webp" alt="" width="56" height="56" loading="lazy" aria-hidden="true" />
          </div>
          <h3 class="option-heading">Email</h3>
          <p class="option-body">{emailCardBody}</p>
          <a href={`mailto:${email}`} class="option-link">
            {email}
            <span aria-hidden="true">&rarr;</span>
          </a>
        </div>

        <!-- WhatsApp -->
        <div class="option-card">
          <div class="option-icon">
            <img src="/Images/Whatsappicon.webp" alt="" width="56" height="56" loading="lazy" aria-hidden="true" />
          </div>
          <h3 class="option-heading">WhatsApp</h3>
          <p class="option-body">{waCardBody}</p>
          <a href={waUrl} class="option-link" target="_blank" rel="noopener noreferrer">
            {phone}
            <span aria-hidden="true">&rarr;</span>
          </a>
        </div>

        <!-- Book a call -->
        <div class="option-card option-card--accent">
          <div class="option-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          </div>
          <h3 class="option-heading">Free discovery call</h3>
          <p class="option-body">{callCardBody}</p>
          <a href={calendly} class="option-cta" target="_blank" rel="noopener noreferrer">
            Book a call
            <span aria-hidden="true">&rarr;</span>
          </a>
        </div>

      </div>
    </div>
  </section>

</Layout>

<style>
  /* ── Shared ───────────────────────────────── */
  .section-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 12px;
  }
  .eyebrow-line {
    display: inline-block;
    width: 24px;
    height: 2px;
    background: var(--gold);
    border-radius: 2px;
    flex-shrink: 0;
  }
  .eyebrow-line--dark { background: var(--primary); }
  .section-eyebrow:has(.eyebrow-line--dark),
  .section-eyebrow--purple { color: var(--primary); }

  /* ── 1. Hero ─────────────────────────────── */
  .contact-hero {
    background:
      linear-gradient(to bottom, rgba(15,12,45,0.68) 0%, rgba(26,23,68,0.90) 100%),
      url('/Images/feldon-haynes-whiteboard-strategy-session.webp') center 30% / cover no-repeat;
    padding: 72px 0 60px;
    min-height: 240px;
    display: flex;
    align-items: center;
  }

  .breadcrumb {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-sans);
    font-size: 13px;
    margin-bottom: 18px;
    color: rgba(255,255,255,0.45);
  }
  .breadcrumb a { color: rgba(255,255,255,0.6); text-decoration: none; }
  .breadcrumb a:hover { color: #fff; }

  .hero-h1 {
    font-family: var(--font-sans);
    font-size: 48px;
    font-weight: 800;
    letter-spacing: -0.03em;
    color: #fff;
    line-height: 1.05;
    margin-bottom: 12px;
  }

  .hero-sub {
    font-family: var(--font-sans);
    font-size: 16px;
    color: rgba(255,255,255,0.65);
    line-height: 1.7;
    max-width: 480px;
  }

  /* ── 2. Quiz ─────────────────────────────── */
  .quiz-section {
    background: var(--surface-tint);
    padding: 80px 0;
    border-top: 1px solid var(--outline-variant);
    border-bottom: 1px solid var(--outline-variant);
  }

  .quiz-wrap {
    display: grid;
    grid-template-columns: 340px 1fr;
    gap: 64px;
    align-items: center;
  }

  .quiz-h2 {
    font-family: var(--font-sans);
    font-size: 36px;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--on-surface);
    line-height: 1.1;
    margin-bottom: 14px;
  }

  .quiz-body {
    font-family: var(--font-sans);
    font-size: 15px;
    color: var(--on-surface-variant);
    line-height: 1.75;
    margin-bottom: 28px;
  }

  .quiz-trust {
    display: flex;
    align-items: center;
    gap: 20px;
  }
  .trust-item { display: flex; flex-direction: column; gap: 2px; }
  .trust-num {
    font-family: var(--font-sans);
    font-size: 26px;
    font-weight: 800;
    color: var(--primary);
    letter-spacing: -0.02em;
    line-height: 1;
  }
  .trust-label {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 500;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .trust-divider {
    width: 1px;
    height: 32px;
    background: var(--outline);
    flex-shrink: 0;
  }

  .quiz-widget-wrap {
    background: var(--surface);
    border: 1px solid var(--outline);
    border-radius: var(--radius-xl);
    padding: 36px;
    box-shadow: var(--shadow-sm);
  }

  /* ── 3. Contact options ──────────────────── */
  .contact-options {
    background: var(--background);
    padding: 80px 0 96px;
  }

  .options-header {
    margin-bottom: 40px;
  }

  .options-h2 {
    font-family: var(--font-sans);
    font-size: 32px;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--on-surface);
    line-height: 1.15;
  }

  .options-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .option-card {
    background: var(--surface);
    border: 1px solid var(--outline);
    border-radius: var(--radius-lg);
    padding: 32px 28px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    transition: box-shadow 0.2s, transform 0.2s;
  }
  .option-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .option-card--accent {
    background: var(--navy);
    border-color: var(--navy);
  }
  .option-card--accent .option-heading,
  .option-card--accent .option-body { color: rgba(255,255,255,0.85); }
  .option-card--accent .option-heading { color: #fff; }
  .option-card--accent .option-icon { color: var(--gold); }

  .option-icon {
    width: 56px;
    height: 56px;
    margin-bottom: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .option-icon img { width: 56px; height: 56px; object-fit: contain; }

  .option-heading {
    font-family: var(--font-sans);
    font-size: 17px;
    font-weight: 700;
    color: var(--on-surface);
    margin-top: 4px;
  }

  .option-body {
    font-family: var(--font-sans);
    font-size: 14px;
    color: var(--on-surface-variant);
    line-height: 1.65;
    flex: 1;
  }

  .option-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 600;
    color: var(--primary);
    text-decoration: none;
    margin-top: 8px;
    transition: gap 0.2s;
  }
  .option-link:hover { gap: 10px; }

  .option-cta {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 700;
    color: var(--gold);
    text-decoration: none;
    margin-top: 8px;
    transition: gap 0.2s;
  }
  .option-cta:hover { gap: 10px; }

  /* ── Responsive ──────────────────────────── */
  @media (max-width: 960px) {
    .options-grid { grid-template-columns: 1fr 1fr; }
    .option-card--accent { grid-column: 1 / -1; flex-direction: row; align-items: center; gap: 24px; }
    .option-card--accent .option-icon { margin-bottom: 0; flex-shrink: 0; }
  }

  @media (max-width: 768px) {
    .quiz-wrap { grid-template-columns: 1fr; gap: 32px; }
    .quiz-h2 { font-size: 28px; }
    .quiz-widget-wrap { padding: 24px 20px; }
  }

  @media (max-width: 600px) {
    .hero-h1 { font-size: 36px; }
    .contact-hero { padding: 52px 0 44px; }
    .quiz-section { padding: 56px 0; }
    .contact-options { padding: 56px 0 72px; }
    .options-grid { grid-template-columns: 1fr; }
    .option-card--accent { flex-direction: column; align-items: flex-start; }
    .options-h2 { font-size: 26px; }
  }
</style>
