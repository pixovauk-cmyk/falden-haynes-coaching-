---
// contact.astro — Contact page
// Primary keyword: find a business coach
// Meta title: "Find a Business Coach | Feldon Haynes" (confirmed in keywords.md)
// Sections: Header → Calendly → Other methods + form
// Schema: BreadcrumbList + ContactPage
// Section rhythm: Header(navy) → Calendly(off-white) → Other(lavender) → Footer

import Layout from '../layouts/Layout.astro';
import QuizWidget from '../components/QuizWidget.astro';

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": "https://feldeluxe.com/"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Contact",
          "item": "https://feldeluxe.com/contact"
        }
      ]
    },
    {
      "@type": "ContactPage",
      "name": "Contact Feldon Haynes Coaching",
      "url": "https://feldeluxe.com/contact",
      "description": "Book a free 30-minute discovery call with Feldon Haynes, business coach and mentor. No pitch, no pressure.",
      "mainEntity": {
        "@type": "Person",
        "@id": "https://feldeluxe.com/about#feldon-haynes",
        "name": "Feldon Haynes",
        "telephone": "+447562614867",
        "email": "info@feldeluxe.com"
      }
    }
  ]
});
---

<Layout
  title="Find a Business Coach | Feldon Haynes"
  description="Find a business coach who's actually built businesses. Book a free 30-minute discovery call with Feldon Haynes. No pitch, no pressure."
  canonicalUrl="https://feldeluxe.com/contact"
  ogImage="/Images/feldon-haynes-professional-headshot.webp"
  preloadImage="/Images/feldon-haynes-thoughtful-portrait.webp"
  preloadImageMobile="/Images/feldon-haynes-whiteboard-strategy-session.webp"
  preloadImageMobileBreakpoint="860px"
  schema={schema}
>

  <!-- ── 1. Page header ────────────────────── -->
  <section class="contact-header" aria-label="Contact page introduction">
    <div class="container">
      <div class="ch-inner">

        <!-- Left: copy -->
        <div class="ch-copy fade-in">
          <nav class="ch-breadcrumb" aria-label="Breadcrumb">
            <a href="/" class="ch-bc-link">Home</a>
            <span class="ch-bc-sep" aria-hidden="true">›</span>
            <span class="ch-bc-cur" aria-current="page">Contact</span>
          </nav>
          <p class="header-eyebrow">
            <span class="eyebrow-line" aria-hidden="true"></span>
            Get in touch
          </p>
          <h1 class="header-h1">Find a business coach who's built one.</h1>
          <p class="header-sub">
            The best place to start is a free 30-minute discovery call.
            No pitch. No pressure. Just a conversation about where you are
            and where you want to go.
          </p>
          <div class="header-pills">
            <span class="header-pill">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><polyline points="12 7 12 12 15 15"/></svg>
              30 minutes
            </span>
            <span class="header-pill">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 12 20 22 4 22 4 12"/><rect x="2" y="7" width="20" height="5"/><line x1="12" y1="22" x2="12" y2="7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/></svg>
              Completely free
            </span>
            <span class="header-pill">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
              Wed &amp; Thu, 8am to 6pm
            </span>
          </div>
        </div>


      </div>
    </div>
  </section>

  <!-- ── 2. Quiz ──────────────────────────────── -->
  <section class="quiz-section" aria-label="Find the right coaching package">
    <div class="qs-split">

      <!-- LEFT: dark navy copy panel -->
      <div class="qs-left">
        <div class="qs-left-inner">
          <p class="qs-eyebrow">
            <span class="qs-eyebrow-line" aria-hidden="true"></span>
            Find your fit
          </p>
          <h2 class="qs-h2">Not sure where<br>to start?</h2>
          <p class="qs-body">
            Eight quick questions. I'll tell you which package fits where you are right now,
            or whether a free call makes more sense first.
          </p>
          <p class="qs-body">
            There is no right or wrong answer. Just pick what feels closest and I'll do the rest.
          </p>

          <div class="qs-trust">
            <div class="qs-trust-item">
              <span class="qs-trust-num">1 min</span>
              <span class="qs-trust-label">to get a recommendation</span>
            </div>
            <div class="qs-trust-divider" aria-hidden="true"></div>
            <div class="qs-trust-item">
              <span class="qs-trust-num">100%</span>
              <span class="qs-trust-label">free, no commitment</span>
            </div>
          </div>

        </div>
      </div>

      <!-- RIGHT: white quiz panel -->
      <div class="qs-right">
        <div class="qs-right-inner fade-in">
          <QuizWidget />
        </div>
      </div>

    </div>
  </section>

  <!-- ── 3. Other ways to reach Feldon ────── -->
  <section class="contact-other" id="other" aria-label="Other ways to get in touch">
    <div class="container">

      <div class="other-header fade-in">
        <p class="other-eyebrow">
          <span class="other-eyebrow-line" aria-hidden="true"></span>
          Other ways to reach me
        </p>
        <h2 class="other-h2">Prefer to message first? That's fine too.</h2>
      </div>

      <div class="other-scroll-wrap" id="other-scroll">
        <div class="other-grid fade-in">

          <!-- Email -->
          <div class="other-card">
            <div class="other-img-wrap" aria-hidden="true">
              <img src="/Images/emailicon.webp" alt="" class="other-app-img" width="96" height="96" loading="lazy" />
            </div>
            <h3 class="other-card-heading">Email</h3>
            <p class="other-card-body">
              Send me a message and I'll reply within 48 hours.
            </p>
            <a href="mailto:info@feldeluxe.com" class="other-card-link">
              info@feldeluxe.com
              <span class="link-arrow" aria-hidden="true">&rarr;</span>
            </a>
          </div>

          <!-- WhatsApp -->
          <div class="other-card">
            <div class="other-img-wrap" aria-hidden="true">
              <img src="/Images/Whatsappicon.webp" alt="" class="other-app-img" width="96" height="96" loading="lazy" />
            </div>
            <h3 class="other-card-heading">WhatsApp</h3>
            <p class="other-card-body">
              Drop me a message on WhatsApp and I'll get back to you.
            </p>
            <a
              href="https://wa.me/07562614867"
              class="other-card-link"
              target="_blank"
              rel="noopener noreferrer"
            >
              07562 614867
              <span class="link-arrow" aria-hidden="true">&rarr;</span>
            </a>
          </div>

        </div>
      </div>

      <!-- Carousel nav (mobile only) -->
      <div class="other-carousel-nav">
        <button class="other-carousel-btn" id="other-prev" aria-label="Previous">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M10 3L5 8l5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <button class="other-carousel-btn" id="other-next" aria-label="Next">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
      </div>

    </div>
  </section>

<script>
  const wrap = document.getElementById('other-scroll');
  const prev = document.getElementById('other-prev');
  const next = document.getElementById('other-next');
  if (wrap && prev && next) {
    const step = () => { const c = wrap.querySelector('.other-card'); return c ? (c as HTMLElement).offsetWidth + 14 : 280; };
    prev.addEventListener('click', () => wrap.scrollBy({ left: -step(), behavior: 'smooth' }));
    next.addEventListener('click', () => wrap.scrollBy({ left: step(), behavior: 'smooth' }));
  }
</script>

</Layout>

<style>
  /* ── 1. Header ─────────────────────────────── */
  .contact-header {
    background:
      linear-gradient(to right, rgba(15,12,45,0.92) 0%, rgba(26,23,68,0.78) 45%, rgba(26,23,68,0.38) 100%),
      url('/Images/feldon-haynes-thoughtful-portrait.webp') center 20%/cover no-repeat;
    overflow: hidden;
  }

  .ch-inner {
    display: grid;
    grid-template-columns: 1fr;
    align-items: center;
    min-height: 520px;
    gap: 0;
    max-width: 700px;
  }

  /* Left: copy */
  .ch-copy {
    padding: 80px 0 72px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  /* Right: photo — hidden on all sizes (bg image used instead) */
  .ch-photo { display: none; }

  /* Breadcrumb */
  .ch-breadcrumb {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 13px;
    font-weight: 500;
    margin-bottom: 24px;
  }
  .ch-bc-link { color: rgba(255,255,255,0.75); text-decoration: none; transition: opacity 0.2s; }
  .ch-bc-link:hover { opacity: 0.9; }
  .ch-bc-sep { color: rgba(255,255,255,0.3); font-size: 16px; }
  .ch-bc-cur { color: rgba(255,255,255,0.45); }

  .header-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #F2D832;
    margin-bottom: 16px;
  }
  .eyebrow-line {
    display: inline-block;
    width: 28px;
    height: 1px;
    background: #F2D832;
    flex-shrink: 0;
  }

  .header-h1 {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 58px;
    font-weight: 800;
    letter-spacing: -0.03em;
    color: #ffffff;
    line-height: 1.05;
    margin-bottom: 20px;
  }

  .header-sub {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 16px;
    font-weight: 400;
    color: rgba(255,255,255,0.72);
    line-height: 1.75;
    margin-bottom: 32px;
  }

  /* Info pills */
  .header-pills {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }
  .header-pill {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 13px;
    font-weight: 600;
    color: #ffffff;
    background: rgba(255,255,255,0.10);
    border: 1px solid rgba(255,255,255,0.20);
    padding: 8px 16px;
    border-radius: 9999px;
    white-space: nowrap;
  }

  /* ── 2. Quiz section ──────────────────────── */
  .quiz-section { overflow: hidden; }

  .qs-split {
    display: grid;
    grid-template-columns: 400px 1fr;
    min-height: 620px;
  }

  /* LEFT — soft lavender copy panel */
  .qs-left {
    background: linear-gradient(160deg, #f4f2ff 0%, #eeedfe 100%);
    display: flex;
    align-items: center;
    border-right: 1px solid #d9d4ff;
  }
  .qs-left-inner {
    padding: 64px 48px;
  }

  .qs-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #534AB7;
    margin-bottom: 20px;
  }
  .qs-eyebrow-line {
    display: inline-block;
    width: 24px;
    height: 1px;
    background: #534AB7;
    flex-shrink: 0;
  }

  .qs-h2 {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 42px;
    font-weight: 800;
    letter-spacing: -0.03em;
    color: #1a1744;
    line-height: 1.1;
    margin-bottom: 20px;
  }

  .qs-body {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 14px;
    color: #7e7a9f;
    line-height: 1.8;
    margin-bottom: 12px;
  }

  .qs-trust {
    display: flex;
    align-items: center;
    gap: 20px;
    margin: 32px 0 28px;
  }
  .qs-trust-item {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .qs-trust-num {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 28px;
    font-weight: 800;
    color: #534AB7;
    letter-spacing: -0.02em;
    line-height: 1;
  }
  .qs-trust-label {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 11px;
    font-weight: 500;
    color: #b0abc8;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .qs-trust-divider {
    width: 1px;
    height: 36px;
    background: #c8c3f5;
    flex-shrink: 0;
  }

  .qs-quote {
    background: rgba(255,255,255,0.6);
    border: 1px solid #c8c3f5;
    border-radius: 12px;
    padding: 16px 18px;
  }
  .qs-quote-text {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 13px;
    font-style: italic;
    color: #3d3a5c;
    line-height: 1.6;
    margin-bottom: 8px;
  }
  .qs-quote-name {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 11px;
    font-weight: 700;
    color: #534AB7;
    letter-spacing: 0.07em;
    text-transform: uppercase;
  }

  /* RIGHT — white quiz panel */
  .qs-right {
    background: #ffffff;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 48px 40px;
  }
  .qs-right-inner {
    width: 100%;
    max-width: 640px;
  }


  /* ── 3. Other contact methods ──────────────── */
  .contact-other {
    background: linear-gradient(135deg, #1a1744 0%, #26215C 55%, #2d2a6e 100%);
    padding: 80px 0;
  }

  .other-header {
    text-align: center;
    margin-bottom: 40px;
  }
  .other-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #F2D832;
    margin-bottom: 14px;
  }
  .other-eyebrow-line {
    display: inline-block;
    width: 28px;
    height: 1px;
    background: #F2D832;
    flex-shrink: 0;
  }
  .other-h2 {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 32px;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: #ffffff;
    line-height: 1.3;
  }

  /* Cards grid: email + whatsapp side by side */
  .other-scroll-wrap { overflow: visible; }
  .other-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    align-items: stretch;
    max-width: 720px;
    margin: 0 auto;
  }

  .other-card {
    background: rgba(255,255,255,0.06);
    border-radius: 18px;
    border: 1px solid rgba(255,255,255,0.12);
    padding: 36px 28px 32px;
    box-shadow: 0 4px 24px rgba(0,0,0,0.2);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 10px;
    transition: background 0.2s, transform 0.2s;
  }
  .other-card:hover {
    background: rgba(255,255,255,0.1);
    transform: translateY(-2px);
  }

  .other-img-wrap {
    width: 96px;
    height: 96px;
    margin-bottom: 10px;
    flex-shrink: 0;
  }
  .other-app-img {
    width: 96px;
    height: 96px;
    object-fit: contain;
    display: block;
  }

  /* Carousel nav — desktop hidden */
  .other-carousel-nav { display: none; }

  .other-card-heading {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 16px;
    font-weight: 700;
    color: #ffffff;
  }
  .other-card-body {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 13px;
    font-weight: 400;
    color: rgba(255,255,255,0.62);
    line-height: 1.7;
    flex: 1;
  }
  .other-card-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 14px;
    font-weight: 600;
    color: #F2D832;
    margin-top: 4px;
    transition: gap 0.2s ease;
  }
  .other-card-link:hover { gap: 10px; }
  .link-arrow { font-size: 16px; line-height: 1; }

  /* ── Responsive ─────────────────────────────── */
  @media (max-width: 1024px) {
    .qs-split { grid-template-columns: 340px 1fr; }
    .qs-left-inner { padding: 48px 32px; }
    .qs-h2 { font-size: 34px; }
  }

  @media (max-width: 860px) {
    /* Mobile: swap to bottom-anchored portrait image */
    .contact-header {
      background:
        linear-gradient(to bottom, rgba(15,12,45,0.45) 0%, rgba(26,23,68,0.82) 55%, #1a1744 100%),
        url('/Images/feldon-haynes-whiteboard-strategy-session.webp') center/cover no-repeat;
      min-height: 480px;
      display: flex;
      align-items: flex-end;
    }
    .ch-inner { min-height: auto; }
    .ch-copy { padding: 40px 0 52px; }
  }

  @media (max-width: 768px) {
    /* Header */
    .header-h1 { font-size: 36px; }
    .header-sub { font-size: 15px; }

    /* Quiz: stack top=copy bottom=quiz */
    .qs-split { grid-template-columns: 1fr; min-height: auto; }
    .qs-left { border-right: none; border-bottom: 1px solid #d9d4ff; }
    .qs-left-inner { padding: 40px 20px 32px; }
    .qs-h2 { font-size: 28px; }
    .qs-trust { margin: 20px 0 18px; }
    .qs-right { padding: 32px 16px 40px; }

    /* Contact — carousel on mobile */
    .contact-other { padding: 48px 0; }
    .other-h2 { font-size: 24px; }
    .other-scroll-wrap {
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      scrollbar-width: none;
      margin: 0 -16px;
      padding: 0 16px 4px;
    }
    .other-scroll-wrap::-webkit-scrollbar { display: none; }
    .other-grid {
      display: flex;
      flex-wrap: nowrap;
      width: max-content;
      gap: 14px;
      max-width: none;
      margin: 0;
    }
    .other-card {
      width: 78vw;
      max-width: 300px;
      flex-shrink: 0;
      scroll-snap-align: start;
    }
    .other-carousel-nav {
      display: flex;
      justify-content: center;
      gap: 10px;
      margin-top: 16px;
    }
    .other-carousel-btn {
      width: 38px;
      height: 38px;
      border-radius: 50%;
      background: rgba(255,255,255,0.15);
      border: 1px solid rgba(255,255,255,0.25);
      color: #ffffff;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      transition: background 0.2s;
    }
    .other-carousel-btn:hover { background: rgba(255,255,255,0.28); }
  }

  @media (max-width: 480px) {
    .header-h1 { font-size: 30px; }
    .header-pills { gap: 8px; }
    .header-pill { font-size: 12px; padding: 6px 12px; }
    .qs-h2 { font-size: 26px; }
    .qs-left-inner { padding: 32px 16px 28px; }
    .qs-right { padding: 24px 12px 36px; }
  }
</style>
